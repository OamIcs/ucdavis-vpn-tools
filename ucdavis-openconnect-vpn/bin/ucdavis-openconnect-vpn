#!/bin/zsh
set -euo pipefail

CONFIG_FILE="${UCD_OPENCONNECT_CONFIG:-$HOME/.config/ucdavis-openconnect-vpn/config.env}"
[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

SCRIPT_DIR="${0:A:h}"
PROGRAM_NAME="${0:t}"
SERVER="${SERVER:-vpn.engineering.ucdavis.edu}"
UC_DAVIS_EMAIL="${UC_DAVIS_EMAIL:-}"
KEYCHAIN_SERVICE="${KEYCHAIN_SERVICE:-ucdavis-openconnect-vpn}"
SSH_HOST_ALIAS="${SSH_HOST_ALIAS:-}"
PING_TARGET="${PING_TARGET:-}"
PING_TARGETS="${PING_TARGETS:-}"
PING_COUNT="${PING_COUNT:-2}"
PING_TIMEOUT_MS="${PING_TIMEOUT_MS:-1500}"
HEALTH_CHECK_MODE="${HEALTH_CHECK_MODE:-auto}"
HEALTH_MIN_SUCCESS="${HEALTH_MIN_SUCCESS:-1}"
TCP_TARGET="${TCP_TARGET:-}"
TCP_TARGETS="${TCP_TARGETS:-}"
TCP_PORT="${TCP_PORT:-22}"
TCP_TIMEOUT_SECONDS="${TCP_TIMEOUT_SECONDS:-3}"
VERIFY_AFTER_CONNECT_SECONDS="${VERIFY_AFTER_CONNECT_SECONDS:-25}"
[[ "$HEALTH_MIN_SUCCESS" == <-> ]] || HEALTH_MIN_SUCCESS=1
(( HEALTH_MIN_SUCCESS > 0 )) || HEALTH_MIN_SUCCESS=1
[[ "$TCP_PORT" == <-> ]] || TCP_PORT=22
[[ "$TCP_TIMEOUT_SECONDS" == <-> ]] || TCP_TIMEOUT_SECONDS=3

STATE_DIR="${STATE_DIR:-$HOME/.local/state/ucdavis-openconnect-vpn}"
LOG_DIR="${LOG_DIR:-$HOME/Library/Logs/ucdavis-openconnect-vpn}"
PID_FILE="${PID_FILE:-$STATE_DIR/openconnect.pid}"
COOKIE_META_FILE="${COOKIE_META_FILE:-$STATE_DIR/cookie-meta.json}"
CHROME_PROFILE_DIR="${CHROME_PROFILE_DIR:-$HOME/.local/state/ucdavis-vpn-chrome-profile}"
CHROME_CDP_PORT="${CHROME_CDP_PORT:-9223}"
CHROME_APP="${CHROME_APP:-Google Chrome}"
CLOSE_WINDOW_AFTER_COOKIE="${CLOSE_WINDOW_AFTER_COOKIE:-1}"
CLOSE_EXISTING_VPN_SESSIONS="${CLOSE_EXISTING_VPN_SESSIONS:-1}"

COOKIE_HELPER="${COOKIE_HELPER:-$SCRIPT_DIR/ucdavis-vpn-cookie.mjs}"
OPENCONNECT_BIN="${OPENCONNECT_BIN:-/opt/homebrew/bin/openconnect}"
VPNC_SCRIPT="${VPNC_SCRIPT:-/opt/homebrew/etc/vpnc/vpnc-script}"
NODE_BIN="${NODE_BIN:-}"
USE_SUDO="${USE_SUDO:-1}"
OPENCONNECT_NO_DTLS="${OPENCONNECT_NO_DTLS:-1}"
OPENCONNECT_EXTRA_ARGS="${OPENCONNECT_EXTRA_ARGS:-}"
LOG_FILE="${LOG_FILE:-$LOG_DIR/openconnect.log}"

mkdir -p "$STATE_DIR" "$LOG_DIR"

find_node() {
  if [[ -n "$NODE_BIN" && -x "$NODE_BIN" ]]; then
    print -r -- "$NODE_BIN"
    return 0
  fi
  if [[ -x /opt/homebrew/bin/node ]]; then
    print -r -- /opt/homebrew/bin/node
    return 0
  fi
  if [[ -x /opt/homebrew/opt/node/bin/node ]]; then
    print -r -- /opt/homebrew/opt/node/bin/node
    return 0
  fi
  if [[ -x /usr/local/bin/node ]]; then
    print -r -- /usr/local/bin/node
    return 0
  fi
  if [[ -x /usr/local/opt/node/bin/node ]]; then
    print -r -- /usr/local/opt/node/bin/node
    return 0
  fi
  if command -v node >/dev/null 2>&1; then
    command -v node
    return 0
  fi
  if [[ -x "/Applications/Codex.app/Contents/Resources/node" ]]; then
    print -r -- "/Applications/Codex.app/Contents/Resources/node"
    return 0
  fi
  return 1
}

NODE_BIN="$(find_node || true)"

usage() {
  cat <<EOF
Usage: $PROGRAM_NAME <command>

Commands:
  status        Show openconnect process, VPN IP, and target reachability.
  doctor        Check local dependencies and keychain entry.
  set-password  Prompt for the VPN password and store it in macOS Keychain.
  cookie        Start/reuse Chrome profile and make sure a VPN cookie exists.
  relogin       Force browser login and refresh the VPN cookie.
  connect       Acquire/reuse cookie, then start openconnect in the background.
  disconnect    Disconnect openconnect with SIGHUP, preserving the login session.
  logout        Terminate openconnect normally, logging out the VPN session.

Config:
  $CONFIG_FILE
EOF
}

pid_from_file() {
  [[ -f "$PID_FILE" ]] || return 1
  local pid
  pid="$(<"$PID_FILE")"
  [[ "$pid" == <-> ]] || return 1
  print -r -- "$pid"
}

pid_running() {
  local pid="$1"
  kill -0 "$pid" >/dev/null 2>&1 || ps -p "$pid" -o pid= >/dev/null 2>&1
}

resolve_ping_target() {
  if [[ -n "$PING_TARGET" ]]; then
    print -r -- "$PING_TARGET"
    return 0
  fi
  if [[ -n "$SSH_HOST_ALIAS" ]]; then
    ssh -G "$SSH_HOST_ALIAS" 2>/dev/null | awk 'tolower($1) == "hostname" { print $2; exit }'
    return 0
  fi
}

ping_health_targets() {
  local target
  for target in ${=PING_TARGETS}; do
    [[ -n "$target" ]] && print -r -- "$target"
  done
  [[ -n "$PING_TARGET" ]] && print -r -- "$PING_TARGET"
  if [[ -z "$PING_TARGETS" && -z "$PING_TARGET" && -n "$SSH_HOST_ALIAS" ]]; then
    resolve_ping_target
  fi
}

network_service_for_device() {
  local device="$1"
  /usr/sbin/networksetup -listallhardwareports 2>/dev/null | awk -v device="$device" '
    /^Hardware Port:/ {
      service=$0
      sub(/^Hardware Port: /, "", service)
    }
    /^Device:/ && $2 == device {
      print service
      exit
    }
  '
}

router_for_device() {
  local device="$1"
  local service
  service="$(network_service_for_device "$device" || true)"
  [[ -n "$service" ]] || return 1
  /usr/sbin/networksetup -getinfo "$service" 2>/dev/null | awk -F': ' '
    $1 == "Router" && $2 != "" && $2 != "none" {
      print $2
      exit
    }
  '
}

default_route_info() {
  local fallback_iface="${1:-}"
  local route_info
  route_info="$(/sbin/route -n get default 2>/dev/null | awk '
    /gateway:/ { gateway=$2 }
    /interface:/ { iface=$2 }
    END { if (gateway || iface) print gateway "|" iface }
  ')"
  if [[ -n "$route_info" ]]; then
    print -r -- "$route_info"
    return 0
  fi

  local iface="$fallback_iface"
  if [[ -z "$iface" ]]; then
    iface="$(/usr/sbin/scutil --nwi 2>/dev/null | awk '
      /IPv4 network interface information/ { in_ipv4=1; next }
      /IPv6 network interface information/ { in_ipv4=0 }
      in_ipv4 && /^[[:space:]]+[[:alnum:]]+[[:space:]]*:/ {
        gsub(":", "", $1)
        print $1
        exit
      }
    ')"
  fi
  [[ -n "$iface" ]] || return 1

  local router
  router="$(router_for_device "$iface" || true)"
  [[ -n "$router" ]] || return 1
  print -r -- "$router|$iface"
}

vpn_server_route_info() {
  /sbin/route -n get "$SERVER" 2>/dev/null | awk '
    /route to:/ { route=$3 }
    /gateway:/ { gateway=$2 }
    /interface:/ { iface=$2 }
    END { if (route || gateway || iface) print route "|" gateway "|" iface }
  '
}

repair_stale_vpn_server_route() {
  local server_info
  server_info="$(vpn_server_route_info || true)"
  [[ -n "$server_info" ]] || return 0

  local -a server_parts default_parts
  server_parts=("${(@ps:|:)server_info}")

  local server_ip="${server_parts[1]:-}"
  local server_gateway="${server_parts[2]:-}"
  local server_iface="${server_parts[3]:-}"
  local default_info
  default_info="$(default_route_info "$server_iface" || true)"
  [[ -n "$default_info" ]] || return 0

  default_parts=("${(@ps:|:)default_info}")
  local default_gateway="${default_parts[1]:-}"
  local default_iface="${default_parts[2]:-}"

  local -a sudo_cmd
  sudo_cmd=()
  if [[ "$USE_SUDO" == "1" ]]; then
    /usr/bin/sudo -v
    sudo_cmd=(/usr/bin/sudo)
  fi

  if ! /sbin/route -n get default >/dev/null 2>&1 && [[ -n "$default_gateway" ]]; then
    print "Default route is missing; restoring default via $default_gateway on $default_iface."
    "${sudo_cmd[@]}" /sbin/route -n add default "$default_gateway" >/dev/null 2>&1 ||
      "${sudo_cmd[@]}" /sbin/route -n change default "$default_gateway" >/dev/null 2>&1 ||
      true
  fi

  if [[ -n "$server_ip" && -n "$server_gateway" && -n "$default_gateway" &&
        "$server_iface" == "$default_iface" && "$server_gateway" != "$default_gateway" ]]; then
    print "VPN server route looks stale: $server_ip via $server_gateway on $server_iface; default is $default_gateway."
    "${sudo_cmd[@]}" /sbin/route -n delete "$server_ip" >/dev/null 2>&1 || true
  fi
}

ping_target_ok() {
  local target="$1"
  [[ -n "$target" ]] || return 1
  /sbin/ping -q -c "$PING_COUNT" -W "$PING_TIMEOUT_MS" "$target" >/dev/null 2>&1
}

split_tcp_target() {
  local value="$1"
  local default_port="${2:-$TCP_PORT}"
  [[ -n "$value" ]] || return 1
  if [[ "$value" == *:* ]]; then
    print -r -- "${value%:*}|${value##*:}"
  else
    print -r -- "$value|$default_port"
  fi
}

resolve_tcp_target() {
  local host
  if [[ -n "$TCP_TARGET" ]]; then
    split_tcp_target "$TCP_TARGET" "$TCP_PORT"
    return 0
  fi
  host="$(resolve_ping_target || true)"
  [[ -n "$host" ]] || return 1
  split_tcp_target "$host" "$TCP_PORT"
}

tcp_health_targets() {
  local target host
  for target in ${=TCP_TARGETS}; do
    [[ -n "$target" ]] && split_tcp_target "$target" "$TCP_PORT"
  done
  [[ -n "$TCP_TARGET" ]] && split_tcp_target "$TCP_TARGET" "$TCP_PORT"
  if [[ -z "$TCP_TARGETS" && -z "$TCP_TARGET" ]]; then
    host="$(resolve_ping_target || true)"
    [[ -n "$host" ]] && split_tcp_target "$host" "$TCP_PORT"
  fi
}

tcp_target_ok() {
  local info="$1"
  local -a parts
  parts=("${(@ps:|:)info}")
  local host="${parts[1]:-}"
  local port="${parts[2]:-$TCP_PORT}"
  [[ -n "$host" && "$port" == <-> ]] || return 1
  /usr/bin/nc -G "$TCP_TIMEOUT_SECONDS" -z "$host" "$port" >/dev/null 2>&1
}

resolved_health_check_mode() {
  case "$HEALTH_CHECK_MODE" in
    ping|tcp|tunnel)
      print -r -- "$HEALTH_CHECK_MODE"
      ;;
    auto|"")
      if [[ -n "$TCP_TARGETS" || -n "$TCP_TARGET" ]]; then
        print tcp
      elif [[ -n "$PING_TARGETS" || -n "$PING_TARGET" || -n "$SSH_HOST_ALIAS" ]]; then
        print ping
      else
        print tunnel
      fi
      ;;
    *)
      print tunnel
      ;;
  esac
}

health_check_description() {
  local mode targets info
  mode="$(resolved_health_check_mode)"
  case "$mode" in
    ping)
      targets="$(ping_health_targets | paste -sd, - 2>/dev/null || true)"
      print -r -- "ping ${targets:-unresolved} (min $HEALTH_MIN_SUCCESS)"
      ;;
    tcp)
      targets="$(tcp_health_targets | while IFS= read -r info; do
        local -a parts
        parts=("${(@ps:|:)info}")
        print -r -- "${parts[1]:-unresolved}:${parts[2]:-$TCP_PORT}"
      done | paste -sd, - 2>/dev/null || true)"
      print -r -- "tcp ${targets:-unresolved} (min $HEALTH_MIN_SUCCESS)"
      ;;
    *)
      print -r -- "tunnel"
      ;;
  esac
}

health_check_ok() {
  local mode target info successes=0 total=0
  mode="$(resolved_health_check_mode)"
  case "$mode" in
    ping)
      while IFS= read -r target; do
        [[ -n "$target" ]] || continue
        total=$((total + 1))
        ping_target_ok "$target" && successes=$((successes + 1))
        (( successes >= HEALTH_MIN_SUCCESS )) && return 0
      done <<< "$(ping_health_targets)"
      (( total > 0 && successes >= HEALTH_MIN_SUCCESS ))
      ;;
    tcp)
      while IFS= read -r info; do
        [[ -n "$info" ]] || continue
        total=$((total + 1))
        tcp_target_ok "$info" && successes=$((successes + 1))
        (( successes >= HEALTH_MIN_SUCCESS )) && return 0
      done <<< "$(tcp_health_targets)"
      (( total > 0 && successes >= HEALTH_MIN_SUCCESS ))
      ;;
    tunnel)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

vpn_session_ok() {
  local pid
  pid="$(pid_from_file 2>/dev/null)" && pid_running "$pid" || return 1
  [[ -n "$(vpn_internal_ip || true)" ]] || return 1
  health_check_ok
}

vpn_internal_ip() {
  /sbin/ifconfig | awk '
    /^utun[0-9]+:/ { iface=$1; sub(":", "", iface) }
    $1 == "inet" && $2 ~ /^172\.2[0-9]\./ { print iface " " $2; exit }
  '
}

chrome_cdp_status() {
  /usr/sbin/lsof -nP -iTCP:"$CHROME_CDP_PORT" -sTCP:LISTEN 2>/dev/null | awk 'NR == 2 { print $1 " pid=" $2; found=1 } END { if (!found) print "" }'
}

json_field() {
  local field="$1"
  "$NODE_BIN" -e '
    const field = process.argv[1];
    let data = "";
    process.stdin.on("data", chunk => data += chunk);
    process.stdin.on("end", () => {
      const json = JSON.parse(data);
      const value = json[field];
      if (Array.isArray(value)) process.stdout.write(value.join(", "));
      else if (value !== undefined && value !== null) process.stdout.write(String(value));
    });
  ' "$field"
}

write_cookie_meta() {
  "$NODE_BIN" -e '
    let data = "";
    process.stdin.on("data", chunk => data += chunk);
    process.stdin.on("end", () => {
      const json = JSON.parse(data);
      delete json.cookie;
      process.stdout.write(JSON.stringify(json, null, 2) + "\n");
    });
  ' > "$COOKIE_META_FILE"
}

acquire_cookie_json() {
  [[ -n "$NODE_BIN" ]] || {
    print -u2 "node was not found. Install node or set NODE_BIN."
    return 1
  }
  UCD_VPN_SERVER="$SERVER" \
  UCD_VPN_EMAIL="$UC_DAVIS_EMAIL" \
  UCD_VPN_KEYCHAIN_SERVICE="$KEYCHAIN_SERVICE" \
  UCD_VPN_PROFILE_DIR="$CHROME_PROFILE_DIR" \
  UCD_VPN_CDP_PORT="$CHROME_CDP_PORT" \
  UCD_VPN_CHROME_APP="$CHROME_APP" \
  UCD_VPN_CLOSE_WINDOW_AFTER_COOKIE="$CLOSE_WINDOW_AFTER_COOKIE" \
  UCD_VPN_CLOSE_EXISTING_SESSIONS="$CLOSE_EXISTING_VPN_SESSIONS" \
    "$NODE_BIN" "$COOKIE_HELPER" --json "$@"
}

command_status() {
  local pid=""
  local process_status="stopped"
  if pid="$(pid_from_file 2>/dev/null)" && pid_running "$pid"; then
    process_status="running (pid $pid)"
  fi

  local health_status health_detail
  health_detail="$(health_check_description)"
  if vpn_session_ok; then
    health_status="OK ($health_detail)"
  else
    health_status="FAIL ($health_detail)"
  fi

  local ip
  ip="$(vpn_internal_ip || true)"
  [[ -n "$ip" ]] || ip="not found"

  local cdp
  cdp="$(chrome_cdp_status || true)"
  [[ -n "$cdp" ]] || cdp="not listening"

  local server_info default_info server_route_status=""
  server_info="$(vpn_server_route_info || true)"
  if [[ -n "$server_info" ]]; then
    local -a server_parts default_parts
    server_parts=("${(@ps:|:)server_info}")
    default_info="$(default_route_info "${server_parts[3]:-}" || true)"
    default_parts=("${(@ps:|:)default_info}")
    if [[ -n "${default_parts[1]:-}" && "${server_parts[3]:-}" == "${default_parts[2]:-}" &&
          -n "${server_parts[2]:-}" && "${server_parts[2]:-}" != "${default_parts[1]:-}" ]]; then
      server_route_status=" stale; default gateway ${default_parts[1]}"
    fi
  fi

  print "OpenConnect: $process_status"
  print "VPN IP:       $ip"
  print "Health:      $health_status"
  [[ -n "$server_info" ]] && print "VPN gateway:  ${server_parts[1]:-unknown} via ${server_parts[2]:-unknown} on ${server_parts[3]:-unknown}${server_route_status}"
  print "Chrome CDP:   $cdp"
  if [[ -f "$COOKIE_META_FILE" ]]; then
    print "Cookie meta:  $COOKIE_META_FILE"
    "$NODE_BIN" -e '
      const fs = require("fs");
      const path = process.argv[1];
      const json = JSON.parse(fs.readFileSync(path, "utf8"));
      console.log(`Cookie:       ${json.ok ? "present" : "missing"} (${(json.cookieNames || []).join(", ") || "none"})`);
      const dsid = (json.cookieExpiries || []).find((cookie) => cookie.name === "DSID");
      if (dsid) console.log(`DSID expiry:  ${dsid.expiresAt}${dsid.session ? " (browser session)" : ""}`);
      console.log(`Checked:      ${json.checkedAt || "unknown"}`);
    ' "$COOKIE_META_FILE" 2>/dev/null || true
  else
    print "Cookie:       no cached metadata"
  fi
}

command_doctor() {
  print "Config:       $CONFIG_FILE"
  print "Server:       $SERVER"
  print "Email:        $UC_DAVIS_EMAIL"
  print "Chrome profile: $CHROME_PROFILE_DIR"
  print "Node:         ${NODE_BIN:-missing}"
  if [[ -x "$OPENCONNECT_BIN" ]]; then
    print "OpenConnect:  $OPENCONNECT_BIN"
    "$OPENCONNECT_BIN" --version | sed -n '1,4p'
  else
    print "OpenConnect:  missing at $OPENCONNECT_BIN"
  fi
  [[ -x "$VPNC_SCRIPT" ]] && print "vpnc-script:  $VPNC_SCRIPT" || print "vpnc-script:  missing at $VPNC_SCRIPT"
  if /usr/bin/security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$UC_DAVIS_EMAIL" >/dev/null 2>&1; then
    print "Keychain:     OK ($KEYCHAIN_SERVICE / $UC_DAVIS_EMAIL)"
  else
    print "Keychain:     missing ($KEYCHAIN_SERVICE / $UC_DAVIS_EMAIL)"
  fi
  print "Health check: $(resolved_health_check_mode) ($(health_check_description))"
}

command_set_password() {
  if [[ -z "$UC_DAVIS_EMAIL" || "$UC_DAVIS_EMAIL" == "your_email@ucdavis.edu" ]]; then
    print -u2 "Set UC_DAVIS_EMAIL in $CONFIG_FILE before storing a password."
    return 1
  fi

  local password
  print "This stores the VPN password in your macOS login Keychain."
  read -rs "password?UC Davis VPN password for $UC_DAVIS_EMAIL: "
  print
  if [[ -z "$password" ]]; then
    print -u2 "Password was empty; nothing stored."
    return 1
  fi

  /usr/bin/security add-generic-password \
    -a "$UC_DAVIS_EMAIL" \
    -s "$KEYCHAIN_SERVICE" \
    -l "UC Davis VPN password" \
    -T /usr/bin/security \
    -U \
    -w "$password"
  unset password
  print "Keychain:     OK ($KEYCHAIN_SERVICE / $UC_DAVIS_EMAIL)"
}

command_cookie() {
  if [[ -z "$UC_DAVIS_EMAIL" ]]; then
    print -u2 "UC_DAVIS_EMAIL is required. Configure $CONFIG_FILE."
    return 1
  fi
  repair_stale_vpn_server_route
  local json
  json="$(acquire_cookie_json "$@")"
  print -r -- "$json" | write_cookie_meta
  local ok names profile
  ok="$(print -r -- "$json" | json_field ok)"
  names="$(print -r -- "$json" | json_field cookieNames)"
  profile="$(print -r -- "$json" | json_field profileDir)"
  print "Cookie:       $([[ "$ok" == "true" ]] && print present || print missing)"
  print "Cookie names: ${names:-none}"
  print "Profile:      $profile"
}

command_relogin() {
  command_cookie --force-login
}

openconnect_args() {
  local -a args
  args=(
    "$OPENCONNECT_BIN"
    --protocol=nc
    --cookie-on-stdin
    --background
    --pid-file "$PID_FILE"
    --script "$VPNC_SCRIPT"
  )
  [[ "$OPENCONNECT_NO_DTLS" == "1" ]] && args+=(--no-dtls)
  if [[ -n "$OPENCONNECT_EXTRA_ARGS" ]]; then
    args+=(${=OPENCONNECT_EXTRA_ARGS})
  fi
  args+=("$SERVER")
  print -r -- "${(@q)args}"
}

command_connect() {
  if [[ -z "$UC_DAVIS_EMAIL" ]]; then
    print -u2 "UC_DAVIS_EMAIL is required. Configure $CONFIG_FILE."
    return 1
  fi
  if [[ -f "$PID_FILE" ]]; then
    local pid
    if pid="$(pid_from_file 2>/dev/null)" && pid_running "$pid"; then
      if vpn_session_ok; then
        print "OpenConnect already running (pid $pid)."
        command_status
        return 0
      fi
      print "OpenConnect is running (pid $pid), but the health check failed ($(health_check_description)); reconnecting."
      signal_openconnect HUP
      sleep 2
    fi
  fi

  repair_stale_vpn_server_route

  local json cookie
  json="$(acquire_cookie_json)"
  print -r -- "$json" | write_cookie_meta
  cookie="$(print -r -- "$json" | json_field cookie)"
  [[ -n "$cookie" ]] || {
    print -u2 "No VPN cookie available."
    return 1
  }

  [[ -x "$OPENCONNECT_BIN" ]] || {
    print -u2 "OpenConnect missing at $OPENCONNECT_BIN"
    return 1
  }
  [[ -x "$VPNC_SCRIPT" ]] || {
    print -u2 "vpnc-script missing at $VPNC_SCRIPT"
    return 1
  }

  local -a sudo_cmd
  sudo_cmd=()
  if [[ "$USE_SUDO" == "1" ]]; then
    /usr/bin/sudo -v
    sudo_cmd=(/usr/bin/sudo)
  fi

  print "Starting OpenConnect; log: $LOG_FILE"
  local -a args
  args=(${(Q)${(z)$(openconnect_args)}})
  if ! print -rn -- "$cookie" | "${sudo_cmd[@]}" "${args[@]}" >> "$LOG_FILE" 2>&1; then
    print "First OpenConnect attempt failed; refreshing browser login cookie and retrying once."
    json="$(acquire_cookie_json --force-login)"
    print -r -- "$json" | write_cookie_meta
    cookie="$(print -r -- "$json" | json_field cookie)"
    [[ -n "$cookie" ]] || {
      print -u2 "No VPN cookie available after relogin."
      return 1
    }
    if ! print -rn -- "$cookie" | "${sudo_cmd[@]}" "${args[@]}" >> "$LOG_FILE" 2>&1; then
      print -u2 "OpenConnect failed. Recent log:"
      tail -n 40 "$LOG_FILE" >&2 || true
      return 1
    fi
  fi

  if [[ ! -f "$PID_FILE" ]]; then
    print -u2 "OpenConnect failed. Recent log:"
    tail -n 40 "$LOG_FILE" >&2 || true
    return 1
  fi

  local elapsed=0
  while (( elapsed < VERIFY_AFTER_CONNECT_SECONDS )); do
    if vpn_session_ok; then
      break
    fi
    sleep 1
    elapsed=$((elapsed + 1))
  done
  command_status
}

signal_openconnect() {
  local signal="$1"
  local pid
  pid="$(pid_from_file 2>/dev/null)" || {
    print "OpenConnect is not running."
    return 0
  }
  if ! pid_running "$pid"; then
    rm -f "$PID_FILE"
    print "OpenConnect pid file was stale."
    return 0
  fi
  if kill "-$signal" "$pid" >/dev/null 2>&1; then
    :
  elif [[ "$USE_SUDO" == "1" ]]; then
    /usr/bin/sudo kill "-$signal" "$pid"
  else
    return 1
  fi
  sleep 1
  rm -f "$PID_FILE"
}

command_disconnect() {
  signal_openconnect HUP
  print "Disconnected with SIGHUP; VPN login session should be preserved if the server allows it."
}

command_logout() {
  signal_openconnect TERM
  print "OpenConnect terminated with logout semantics."
}

case "${1:-}" in
  status) command_status ;;
  doctor) command_doctor ;;
  set-password|password|store-password) command_set_password ;;
  cookie) command_cookie ;;
  relogin) command_relogin ;;
  connect) command_connect ;;
  disconnect) command_disconnect ;;
  logout) command_logout ;;
  -h|--help|help|"") usage ;;
  *)
    print -u2 "Unknown command: $1"
    usage
    exit 2
    ;;
esac
