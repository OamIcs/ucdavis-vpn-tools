#!/bin/zsh
set -euo pipefail

CONFIG_FILE="/Library/Application Support/ucdavis-vpn-daemon/config.env"
COMMAND="run"
PROGRAM_NAME="${0:t}"

while (( $# > 0 )); do
  case "$1" in
    --config)
      CONFIG_FILE="$2"
      shift 2
      ;;
    run|once|status|connect|disconnect|logout|doctor|pause|resume|disable|enable)
      COMMAND="$1"
      shift
      ;;
    -h|--help|help)
      COMMAND="help"
      shift
      ;;
    *)
      print -u2 "Unknown argument: $1"
      exit 2
      ;;
  esac
done

[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

LABEL="${LABEL:-local.ucdavis-openconnect-daemon}"

detect_console_user() {
  /usr/bin/stat -f %Su /dev/console 2>/dev/null
}

USER_NAME="${USER_NAME:-$(detect_console_user)}"
[[ "$USER_NAME" == "root" || -z "$USER_NAME" ]] && USER_NAME="${SUDO_USER:-}"
USER_UID="${USER_UID:-$(/usr/bin/id -u "$USER_NAME" 2>/dev/null || true)}"
USER_HOME="${USER_HOME:-$(/usr/bin/dscl . -read "/Users/$USER_NAME" NFSHomeDirectory 2>/dev/null | /usr/bin/awk '{print $2}' || true)}"
USER_HOME="${USER_HOME:-/Users/$USER_NAME}"

SERVER="${SERVER:-vpn.engineering.ucdavis.edu}"
UC_DAVIS_EMAIL="${UC_DAVIS_EMAIL:-}"
KEYCHAIN_SERVICE="${KEYCHAIN_SERVICE:-ucdavis-openconnect-vpn}"

SSH_HOST_ALIAS="${SSH_HOST_ALIAS:-}"
PING_TARGET="${PING_TARGET:-}"
PING_COUNT="${PING_COUNT:-2}"
PING_TIMEOUT_MS="${PING_TIMEOUT_MS:-1500}"
CHECK_INTERVAL_SECONDS="${CHECK_INTERVAL_SECONDS:-60}"
FAILURE_THRESHOLD="${FAILURE_THRESHOLD:-2}"
RECONNECT_COOLDOWN_SECONDS="${RECONNECT_COOLDOWN_SECONDS:-180}"
VERIFY_AFTER_CONNECT_SECONDS="${VERIFY_AFTER_CONNECT_SECONDS:-25}"
GUI_SESSION_WAIT_SECONDS="${GUI_SESSION_WAIT_SECONDS:-0}"
GUI_SESSION_POLL_SECONDS="${GUI_SESSION_POLL_SECONDS:-1}"
AUTO_RECONNECT="${AUTO_RECONNECT:-1}"
CONNECT_ON_START="${CONNECT_ON_START:-1}"
MAX_BROWSER_SESSION_ATTEMPTS="${MAX_BROWSER_SESSION_ATTEMPTS:-2}"
[[ "$MAX_BROWSER_SESSION_ATTEMPTS" == <-> ]] || MAX_BROWSER_SESSION_ATTEMPTS=2

STATE_DIR="${STATE_DIR:-/var/run/ucdavis-openconnect-daemon}"
DB_DIR="${DB_DIR:-/var/db/ucdavis-openconnect-daemon}"
LOG_DIR="${LOG_DIR:-/var/log/ucdavis-openconnect-daemon}"
PID_FILE="${PID_FILE:-$STATE_DIR/openconnect.pid}"
COOKIE_META_FILE="${COOKIE_META_FILE:-$DB_DIR/cookie-meta.json}"
RUN_LOCK_DIR="${RUN_LOCK_DIR:-$DB_DIR/run.lock}"
BROWSER_SESSION_ATTEMPTS_FILE="${BROWSER_SESSION_ATTEMPTS_FILE:-$STATE_DIR/browser-session-attempts}"
BROWSER_SESSION_BLOCK_FILE="${BROWSER_SESSION_BLOCK_FILE:-$STATE_DIR/browser-session.blocked}"
AUTO_RECONNECT_PAUSE_FILE="${AUTO_RECONNECT_PAUSE_FILE:-$STATE_DIR/auto-reconnect.paused}"
CONTROL_DIR="${CONTROL_DIR:-$STATE_DIR/control}"
CONTROL_RESPONSE_DIR="${CONTROL_RESPONSE_DIR:-$STATE_DIR/control/responses}"
CONTROL_POLL_SECONDS="${CONTROL_POLL_SECONDS:-1}"
[[ "$CONTROL_POLL_SECONDS" == <-> ]] || CONTROL_POLL_SECONDS=1
(( CONTROL_POLL_SECONDS > 0 )) || CONTROL_POLL_SECONDS=1
DAEMON_LOG_FILE="${DAEMON_LOG_FILE:-$LOG_DIR/daemon.log}"
OPENCONNECT_LOG_FILE="${OPENCONNECT_LOG_FILE:-$LOG_DIR/openconnect.log}"

NODE_BIN="${NODE_BIN:-}"
COOKIE_HELPER="${COOKIE_HELPER:-}"
OPENCONNECT_BIN="${OPENCONNECT_BIN:-/opt/homebrew/bin/openconnect}"
VPNC_SCRIPT="${VPNC_SCRIPT:-/opt/homebrew/etc/vpnc/vpnc-script}"
OPENCONNECT_NO_DTLS="${OPENCONNECT_NO_DTLS:-1}"
OPENCONNECT_EXTRA_ARGS="${OPENCONNECT_EXTRA_ARGS:-}"

CHROME_PROFILE_DIR="${CHROME_PROFILE_DIR:-$USER_HOME/.local/state/ucdavis-vpn-chrome-profile}"
CHROME_CDP_PORT="${CHROME_CDP_PORT:-9223}"
CHROME_APP="${CHROME_APP:-Google Chrome}"
CLOSE_WINDOW_AFTER_COOKIE="${CLOSE_WINDOW_AFTER_COOKIE:-1}"

RETRY_WITHOUT_COOLDOWN_RC=75
BROWSER_SESSION_BLOCK_RC=76

mkdir -p "$STATE_DIR" "$DB_DIR" "$LOG_DIR" 2>/dev/null || true

find_node() {
  if [[ -n "$NODE_BIN" && -x "$NODE_BIN" ]]; then
    print -r -- "$NODE_BIN"
    return 0
  fi
  if [[ -x /opt/homebrew/bin/node ]]; then
    print -r -- /opt/homebrew/bin/node
    return 0
  fi
  if [[ -x /usr/local/bin/node ]]; then
    print -r -- /usr/local/bin/node
    return 0
  fi
  if command -v node >/dev/null 2>&1; then
    command -v node
    return 0
  fi
  if [[ -x /Applications/Codex.app/Contents/Resources/node ]]; then
    print -r -- /Applications/Codex.app/Contents/Resources/node
    return 0
  fi
  return 1
}

NODE_BIN="$(find_node || true)"

usage() {
  cat <<EOF
Usage: $PROGRAM_NAME [--config path] <command>

Commands:
  run          Long-running launchd mode.
  once         Run one monitor check.
  status       Print tracked OpenConnect, VPN IP, ping, and cookie metadata.
  connect      Connect now, using or refreshing the browser cookie.
  disconnect   Send SIGHUP to OpenConnect, preserving the web login session.
  logout       Send SIGTERM to OpenConnect, logging out the VPN session.
  pause        Pause automatic reconnect.
  resume       Resume automatic reconnect.
  disable      Pause automatic reconnect and disconnect the tunnel.
  enable       Resume automatic reconnect and connect now.
  doctor       Check dependencies and root/user context.

Config:
  $CONFIG_FILE
EOF
}

timestamp() {
  /bin/date "+%Y-%m-%d %H:%M:%S%z"
}

log() {
  local line="[$(timestamp)] $*"
  print -r -- "$line"
  print -r -- "$line" >> "$DAEMON_LOG_FILE"
}

require_root() {
  if [[ "$(id -u)" != "0" ]]; then
    print -u2 "This command must run as root."
    exit 1
  fi
}

pid_from_file() {
  [[ -f "$PID_FILE" ]] || return 1
  local pid
  pid="$(<"$PID_FILE")"
  [[ "$pid" == <-> ]] || return 1
  print -r -- "$pid"
}

pid_running() {
  local pid="$1"
  kill -0 "$pid" >/dev/null 2>&1 || ps -p "$pid" -o pid= >/dev/null 2>&1
}

launchd_tracked_pid() {
  /bin/launchctl print "system/$LABEL" 2>/dev/null | /usr/bin/awk '
    /^[[:space:]]*pid = [0-9]+$/ { print $3; exit }
  '
}

acquire_run_lock() {
  local self_pid="${ZSH_PID:-$$}"
  local lock_pid=""
  local tracked_pid=""
  while ! mkdir "$RUN_LOCK_DIR" 2>/dev/null; do
    lock_pid=""
    [[ -f "$RUN_LOCK_DIR/pid" ]] && lock_pid="$(<"$RUN_LOCK_DIR/pid")"
    if [[ "$lock_pid" == <-> ]] && pid_running "$lock_pid"; then
      tracked_pid="$(launchd_tracked_pid || true)"
      if [[ "$tracked_pid" == "$lock_pid" && "$self_pid" != "$tracked_pid" ]]; then
        log "Daemon singleton lock is held by launchd-tracked pid $lock_pid; exiting duplicate launcher pid $self_pid."
        exit 0
      fi
      log "Another daemon loop is active as pid $lock_pid; launcher pid $self_pid is standing by."
      while [[ "$lock_pid" == <-> ]] && pid_running "$lock_pid"; do
        sleep "$CHECK_INTERVAL_SECONDS"
        [[ -f "$RUN_LOCK_DIR/pid" ]] && lock_pid="$(<"$RUN_LOCK_DIR/pid")" || lock_pid=""
      done
      log "Daemon singleton lock holder exited; trying to acquire lock."
      rm -rf "$RUN_LOCK_DIR"
      continue
    fi
    log "Removing stale daemon singleton lock."
    rm -rf "$RUN_LOCK_DIR"
  done
  print -r -- "$self_pid" > "$RUN_LOCK_DIR/pid"
  log "Acquired daemon singleton lock as pid $self_pid."
}

tracked_pid_status() {
  local pid
  if pid="$(pid_from_file 2>/dev/null)" && pid_running "$pid"; then
    print -r -- "running (pid $pid)"
  else
    print -r -- "stopped"
  fi
}

resolve_ping_target() {
  if [[ -n "$PING_TARGET" ]]; then
    print -r -- "$PING_TARGET"
    return 0
  fi
  if [[ -n "$SSH_HOST_ALIAS" ]]; then
    if [[ "$(id -u)" == "$USER_UID" ]]; then
      HOME="$USER_HOME" /usr/bin/ssh -G "$SSH_HOST_ALIAS" 2>/dev/null |
        /usr/bin/awk 'tolower($1) == "hostname" { print $2; exit }'
    else
      /usr/bin/sudo -u "$USER_NAME" HOME="$USER_HOME" /usr/bin/ssh -G "$SSH_HOST_ALIAS" 2>/dev/null |
        /usr/bin/awk 'tolower($1) == "hostname" { print $2; exit }'
    fi
    return 0
  fi
}

network_service_for_device() {
  local device="$1"
  /usr/sbin/networksetup -listallhardwareports 2>/dev/null | /usr/bin/awk -v device="$device" '
    /^Hardware Port:/ {
      service=$0
      sub(/^Hardware Port: /, "", service)
    }
    /^Device:/ && $2 == device {
      print service
      exit
    }
  '
}

router_for_device() {
  local device="$1"
  local service
  service="$(network_service_for_device "$device" || true)"
  [[ -n "$service" ]] || return 1
  /usr/sbin/networksetup -getinfo "$service" 2>/dev/null | /usr/bin/awk -F': ' '
    $1 == "Router" && $2 != "" && $2 != "none" {
      print $2
      exit
    }
  '
}

default_route_info() {
  local fallback_iface="${1:-}"
  local route_info
  route_info="$(/sbin/route -n get default 2>/dev/null | /usr/bin/awk '
    /gateway:/ { gateway=$2 }
    /interface:/ { iface=$2 }
    END { if (gateway || iface) print gateway "|" iface }
  ')"
  if [[ -n "$route_info" ]]; then
    print -r -- "$route_info"
    return 0
  fi

  local iface="$fallback_iface"
  if [[ -z "$iface" ]]; then
    iface="$(/usr/sbin/scutil --nwi 2>/dev/null | /usr/bin/awk '
      /IPv4 network interface information/ { in_ipv4=1; next }
      /IPv6 network interface information/ { in_ipv4=0 }
      in_ipv4 && /^[[:space:]]+[[:alnum:]]+[[:space:]]*:/ {
        gsub(":", "", $1)
        print $1
        exit
      }
    ')"
  fi
  [[ -n "$iface" ]] || return 1

  local router
  router="$(router_for_device "$iface" || true)"
  [[ -n "$router" ]] || return 1
  print -r -- "$router|$iface"
}

vpn_server_route_info() {
  /sbin/route -n get "$SERVER" 2>/dev/null | /usr/bin/awk '
    /route to:/ { route=$3 }
    /gateway:/ { gateway=$2 }
    /interface:/ { iface=$2 }
    END { if (route || gateway || iface) print route "|" gateway "|" iface }
  '
}

repair_stale_vpn_server_route() {
  local server_info
  server_info="$(vpn_server_route_info || true)"
  [[ -n "$server_info" ]] || return 0

  local -a server_parts default_parts
  server_parts=("${(@ps:|:)server_info}")

  local server_ip="${server_parts[1]:-}"
  local server_gateway="${server_parts[2]:-}"
  local server_iface="${server_parts[3]:-}"
  local default_info
  default_info="$(default_route_info "$server_iface" || true)"
  [[ -n "$default_info" ]] || return 0

  default_parts=("${(@ps:|:)default_info}")
  local default_gateway="${default_parts[1]:-}"
  local default_iface="${default_parts[2]:-}"

  if ! /sbin/route -n get default >/dev/null 2>&1 && [[ -n "$default_gateway" ]]; then
    log "Default route is missing; restoring default via $default_gateway on $default_iface."
    /sbin/route -n add default "$default_gateway" >/dev/null 2>&1 ||
      /sbin/route -n change default "$default_gateway" >/dev/null 2>&1 ||
      true
  fi

  if [[ -n "$server_ip" && -n "$server_gateway" && -n "$default_gateway" &&
        "$server_iface" == "$default_iface" && "$server_gateway" != "$default_gateway" ]]; then
    log "VPN server route looks stale: $server_ip via $server_gateway on $server_iface; default is $default_gateway. Deleting route before reconnect."
    /sbin/route -n delete "$server_ip" >/dev/null 2>&1 || true
  fi
}

ping_target_ok() {
  local target="$1"
  [[ -n "$target" ]] || return 1
  /sbin/ping -q -c "$PING_COUNT" -W "$PING_TIMEOUT_MS" "$target" >/dev/null 2>&1
}

vpn_internal_ip() {
  /sbin/ifconfig | /usr/bin/awk '
    /^utun[0-9]+:/ { iface=$1; sub(":", "", iface) }
    $1 == "inet" && $2 ~ /^172\.2[0-9]\./ { print iface " " $2; exit }
  '
}

any_openconnect() {
  /bin/ps -axo user=,pid=,command= |
    /usr/bin/awk '
      /(^|[[:space:]])([^[:space:]]*\/)?[o]penconnect([[:space:]]|$)/ {
        print
        found=1
      }
      END { exit found ? 0 : 1 }
    '
}

user_gui_available() {
  /bin/launchctl print "gui/$USER_UID" >/dev/null 2>&1
}

setup_control_dir() {
  require_root
  mkdir -p "$CONTROL_DIR" "$CONTROL_RESPONSE_DIR"
  chown "$USER_NAME" "$CONTROL_DIR" "$CONTROL_RESPONSE_DIR" >/dev/null 2>&1 || true
  chmod 0700 "$CONTROL_DIR" "$CONTROL_RESPONSE_DIR" >/dev/null 2>&1 || true
}

auto_reconnect_paused() {
  [[ -f "$AUTO_RECONNECT_PAUSE_FILE" ]]
}

set_auto_reconnect_paused() {
  mkdir -p "$STATE_DIR" 2>/dev/null || true
  {
    print "paused_at=$(timestamp)"
    print "reason=${1:-manual pause}"
  } > "$AUTO_RECONNECT_PAUSE_FILE"
  log "Automatic reconnect paused: ${1:-manual pause}."
}

clear_auto_reconnect_paused() {
  local reason="${1:-manual resume}"
  if [[ -f "$AUTO_RECONNECT_PAUSE_FILE" ]]; then
    rm -f "$AUTO_RECONNECT_PAUSE_FILE"
    log "Automatic reconnect resumed: $reason."
  fi
}

auto_reconnect_status() {
  local reason
  if auto_reconnect_paused; then
    reason="$(/usr/bin/awk -F= '$1 == "reason" { print $2; exit }' "$AUTO_RECONNECT_PAUSE_FILE" 2>/dev/null || true)"
    print "paused${reason:+ ($reason)}"
  else
    print "$([[ "$AUTO_RECONNECT" == "1" ]] && print active || print disabled)"
  fi
}

browser_session_attempt_count() {
  local count=0
  if [[ -f "$BROWSER_SESSION_ATTEMPTS_FILE" ]]; then
    count="$(<"$BROWSER_SESSION_ATTEMPTS_FILE")"
  fi
  [[ "$count" == <-> ]] || count=0
  print -r -- "$count"
}

browser_session_blocked() {
  (( MAX_BROWSER_SESSION_ATTEMPTS > 0 )) && [[ -f "$BROWSER_SESSION_BLOCK_FILE" ]]
}

browser_session_budget_exhausted() {
  (( MAX_BROWSER_SESSION_ATTEMPTS > 0 )) &&
    (( $(browser_session_attempt_count) >= MAX_BROWSER_SESSION_ATTEMPTS ))
}

block_browser_session_attempts() {
  local count reason
  count="$(browser_session_attempt_count)"
  reason="${1:-browser session attempt limit reached}"
  {
    print "blocked_at=$(timestamp)"
    print "attempts=$count"
    print "max=$MAX_BROWSER_SESSION_ATTEMPTS"
    print "reason=$reason"
  } > "$BROWSER_SESSION_BLOCK_FILE"
  log "Browser session attempts are blocked after $count/$MAX_BROWSER_SESSION_ATTEMPTS attempts; run '$PROGRAM_NAME connect' after manual recovery."
}

block_browser_session_attempts_if_exhausted() {
  local reason="${1:-browser session attempt limit reached}"
  if ! browser_session_blocked && browser_session_budget_exhausted; then
    block_browser_session_attempts "$reason"
    return "$BROWSER_SESSION_BLOCK_RC"
  fi
  browser_session_blocked && return "$BROWSER_SESSION_BLOCK_RC"
  return 0
}

reset_browser_session_attempts() {
  local reason="${1:-manual connect}"
  if [[ -f "$BROWSER_SESSION_ATTEMPTS_FILE" || -f "$BROWSER_SESSION_BLOCK_FILE" ]]; then
    rm -f "$BROWSER_SESSION_ATTEMPTS_FILE" "$BROWSER_SESSION_BLOCK_FILE"
    log "Reset browser session attempt state: $reason."
  fi
  return 0
}

record_browser_session_attempt() {
  local mode="$1"
  local count next
  (( MAX_BROWSER_SESSION_ATTEMPTS > 0 )) || return 0
  if browser_session_blocked; then
    log "Browser session attempts are currently blocked; run '$PROGRAM_NAME connect' after manual recovery."
    return "$BROWSER_SESSION_BLOCK_RC"
  fi
  count="$(browser_session_attempt_count)"
  if (( count >= MAX_BROWSER_SESSION_ATTEMPTS )); then
    block_browser_session_attempts "attempt limit reached before $mode"
    return "$BROWSER_SESSION_BLOCK_RC"
  fi
  next=$(( count + 1 ))
  print -r -- "$next" > "$BROWSER_SESSION_ATTEMPTS_FILE"
  log "Browser session attempt $next/$MAX_BROWSER_SESSION_ATTEMPTS ($mode)."
  if (( next >= MAX_BROWSER_SESSION_ATTEMPTS )); then
    log "This is the last automatic browser session attempt before manual connect is required."
  fi
  return 0
}

browser_session_budget_status() {
  local count block_summary
  count="$(browser_session_attempt_count)"
  if (( MAX_BROWSER_SESSION_ATTEMPTS <= 0 )); then
    print "unlimited"
    return 0
  fi
  if browser_session_blocked; then
    block_summary="$(/usr/bin/awk -F= '
      $1 == "blocked_at" { blocked_at=$2 }
      $1 == "reason" { reason=$2 }
      END {
        if (blocked_at || reason) print "blocked since " blocked_at (reason ? "; " reason : "")
      }
    ' "$BROWSER_SESSION_BLOCK_FILE" 2>/dev/null || true)"
    print "blocked ($count/$MAX_BROWSER_SESSION_ATTEMPTS${block_summary:+; $block_summary})"
  else
    print "$count/$MAX_BROWSER_SESSION_ATTEMPTS"
  fi
}

control_request_field() {
  local file="$1"
  local key="$2"
  /usr/bin/awk -F= -v key="$key" '$1 == key { print substr($0, length(key) + 2); exit }' "$file" 2>/dev/null
}

write_control_response() {
  local id="$1"
  local code="$2"
  local output="$3"
  local tmp="$CONTROL_RESPONSE_DIR/$id.response.tmp.$$"
  local response="$CONTROL_RESPONSE_DIR/$id.response"
  {
    print "exit=$code"
    print "output<<EOF"
    print -r -- "$output"
    print "EOF"
  } > "$tmp"
  chown "$USER_NAME" "$tmp" >/dev/null 2>&1 || true
  chmod 0600 "$tmp" >/dev/null 2>&1 || true
  mv "$tmp" "$response"
}

handle_control_command() {
  local command="$1"
  local old_command rc
  case "$command" in
    status)
      command_status
      ;;
    connect)
      clear_auto_reconnect_paused "manual connect"
      old_command="$COMMAND"
      COMMAND=connect
      command_connect
      rc=$?
      COMMAND="$old_command"
      return "$rc"
      ;;
    disconnect)
      command_disconnect
      ;;
    pause)
      command_pause
      ;;
    resume)
      command_resume
      ;;
    disable|off)
      command_disable
      ;;
    enable|on)
      command_enable
      ;;
    once)
      monitor_once
      ;;
    *)
      print -u2 "Unsupported control command: $command"
      return 2
      ;;
  esac
}

process_control_requests() {
  emulate -L zsh
  setopt null_glob
  local request owner id command output rc
  for request in "$CONTROL_DIR"/*.request; do
    [[ -f "$request" ]] || continue
    owner="$(/usr/bin/stat -f %u "$request" 2>/dev/null || true)"
    if [[ -n "$USER_UID" && "$owner" != "$USER_UID" ]]; then
      log "Ignoring control request not owned by uid $USER_UID: $request"
      rm -f "$request"
      continue
    fi
    id="${request:t:r}"
    command="$(control_request_field "$request" command)"
    rm -f "$request"
    if output="$(handle_control_command "$command" 2>&1)"; then
      rc=0
    else
      rc=$?
    fi
    write_control_response "$id" "$rc" "$output"
  done
}

sleep_with_control() {
  local remaining="$1"
  local slice
  while (( remaining > 0 )); do
    process_control_requests
    slice="$CONTROL_POLL_SECONDS"
    (( slice > remaining )) && slice="$remaining"
    sleep "$slice"
    remaining=$(( remaining - slice ))
  done
}

wait_for_user_gui() {
  local start now elapsed
  user_gui_available && return 0

  start="$(date +%s)"
  if (( GUI_SESSION_WAIT_SECONDS > 0 )); then
    log "Waiting up to ${GUI_SESSION_WAIT_SECONDS}s for GUI session gui/$USER_UID before browser login."
  else
    log "Waiting for GUI session gui/$USER_UID before browser login."
  fi

  while true; do
    sleep "$GUI_SESSION_POLL_SECONDS"
    if user_gui_available; then
      now="$(date +%s)"
      elapsed=$(( now - start ))
      log "GUI session gui/$USER_UID is available after ${elapsed}s; starting browser login helper."
      return 0
    fi
    (( GUI_SESSION_WAIT_SECONDS <= 0 )) && continue
    now="$(date +%s)"
    (( now - start >= GUI_SESSION_WAIT_SECONDS )) && return 1
  done
}

run_cookie_helper() {
  local helper_output helper_rc
  [[ -n "$USER_NAME" && -n "$USER_UID" && -n "$USER_HOME" ]] || {
    log "USER_NAME, USER_UID, and USER_HOME must be configured."
    return 1
  }
  [[ -n "$UC_DAVIS_EMAIL" ]] || {
    log "UC_DAVIS_EMAIL must be configured."
    return 1
  }
  [[ -n "$COOKIE_HELPER" ]] || {
    log "COOKIE_HELPER must be configured."
    return 1
  }
  wait_for_user_gui || {
    log "GUI session gui/$USER_UID is not available after ${GUI_SESSION_WAIT_SECONDS}s; will retry without reconnect cooldown."
    return "$RETRY_WITHOUT_COOLDOWN_RC"
  }
  [[ -x "$NODE_BIN" ]] || {
    log "Node binary not executable: $NODE_BIN"
    return 1
  }
  [[ -f "$COOKIE_HELPER" ]] || {
    log "Cookie helper missing: $COOKIE_HELPER"
    return 1
  }

  local mode="reuse existing session"
  [[ " $* " == *" --force-login "* ]] && mode="force browser login"
  local attempt_rc
  record_browser_session_attempt "$mode" || {
    attempt_rc=$?
    return "$attempt_rc"
  }

  helper_output="$STATE_DIR/cookie-helper-output.$$"
  rm -f "$helper_output"
  /bin/launchctl asuser "$USER_UID" /usr/bin/sudo -u "$USER_NAME" \
    /usr/bin/env \
      HOME="$USER_HOME" \
      USER="$USER_NAME" \
      LOGNAME="$USER_NAME" \
      PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin" \
      UCD_VPN_SERVER="$SERVER" \
      UCD_VPN_EMAIL="$UC_DAVIS_EMAIL" \
      UCD_VPN_KEYCHAIN_SERVICE="$KEYCHAIN_SERVICE" \
      UCD_VPN_PROFILE_DIR="$CHROME_PROFILE_DIR" \
      UCD_VPN_CDP_PORT="$CHROME_CDP_PORT" \
      UCD_VPN_CHROME_APP="$CHROME_APP" \
      UCD_VPN_CLOSE_WINDOW_AFTER_COOKIE="$CLOSE_WINDOW_AFTER_COOKIE" \
      "$NODE_BIN" "$COOKIE_HELPER" --json "$@" > "$helper_output"
  helper_rc=$?
  if (( helper_rc != 0 )); then
    rm -f "$helper_output"
    return "$helper_rc"
  fi
  if [[ ! -s "$helper_output" ]]; then
    log "Cookie helper completed without JSON output."
    rm -f "$helper_output"
    return 1
  fi
  cat "$helper_output"
  rm -f "$helper_output"
}

json_field() {
  local field="$1"
  "$NODE_BIN" -e '
    const field = process.argv[1];
    let data = "";
    process.stdin.on("data", chunk => data += chunk);
    process.stdin.on("end", () => {
      try {
        const json = JSON.parse(data);
        const value = json[field];
        if (Array.isArray(value)) process.stdout.write(value.join(", "));
        else if (value !== undefined && value !== null) process.stdout.write(String(value));
      } catch {
        process.exit(2);
      }
    });
  ' "$field"
}

write_cookie_meta() {
  local tmp="$COOKIE_META_FILE.tmp.$$"
  "$NODE_BIN" -e '
    let data = "";
    process.stdin.on("data", chunk => data += chunk);
    process.stdin.on("end", () => {
      try {
        const json = JSON.parse(data);
        delete json.cookie;
        process.stdout.write(JSON.stringify(json, null, 2) + "\n");
      } catch {
        process.exit(2);
      }
    });
  ' > "$tmp" && mv "$tmp" "$COOKIE_META_FILE"
  local rc=$?
  [[ "$rc" == "0" ]] || rm -f "$tmp"
  return "$rc"
}

openconnect_args() {
  local -a args
  args=(
    "$OPENCONNECT_BIN"
    --protocol=nc
    --cookie-on-stdin
    --background
    --pid-file "$PID_FILE"
    --script "$VPNC_SCRIPT"
  )
  [[ "$OPENCONNECT_NO_DTLS" == "1" ]] && args+=(--no-dtls)
  if [[ -n "$OPENCONNECT_EXTRA_ARGS" ]]; then
    args+=(${=OPENCONNECT_EXTRA_ARGS})
  fi
  args+=("$SERVER")
  print -r -- "${(@q)args}"
}

signal_tracked_openconnect() {
  local signal="$1"
  local pid
  pid="$(pid_from_file 2>/dev/null)" || return 0
  if ! pid_running "$pid"; then
    rm -f "$PID_FILE"
    return 0
  fi
  kill "-$signal" "$pid" >/dev/null 2>&1 || true
  sleep 1
  [[ "$signal" == "HUP" || "$signal" == "TERM" ]] && rm -f "$PID_FILE"
}

start_openconnect_with_cookie() {
  local json="$1"
  local cookie
  if ! print -r -- "$json" | write_cookie_meta; then
    log "Cookie helper returned invalid JSON."
    return 1
  fi
  cookie="$(print -r -- "$json" | json_field cookie || true)"
  [[ -n "$cookie" ]] || {
    log "No VPN cookie available."
    return 1
  }

  [[ -x "$OPENCONNECT_BIN" ]] || {
    log "OpenConnect missing: $OPENCONNECT_BIN"
    return 1
  }
  [[ -x "$VPNC_SCRIPT" ]] || {
    log "vpnc-script missing: $VPNC_SCRIPT"
    return 1
  }

  local -a args
  args=(${(Q)${(z)$(openconnect_args)}})
  log "Starting OpenConnect."
  if ! print -rn -- "$cookie" | "${args[@]}" >> "$OPENCONNECT_LOG_FILE" 2>&1; then
    log "OpenConnect start command failed."
    return 1
  fi
  if [[ ! -f "$PID_FILE" ]]; then
    log "OpenConnect did not write pid file."
    return 1
  fi
  return 0
}

command_connect() {
  require_root
  if [[ "$COMMAND" == "connect" ]]; then
    reset_browser_session_attempts "manual connect"
  fi
  local pid
  if pid="$(pid_from_file 2>/dev/null)" && pid_running "$pid"; then
    local target
    target="$(resolve_ping_target || true)"
    if [[ -n "$target" ]] && ping_target_ok "$target"; then
      reset_browser_session_attempts "connectivity OK"
      log "OpenConnect already running as pid $pid."
      return 0
    fi
    if browser_session_blocked; then
      log "VPN reconnect is blocked by the browser session attempt limit; run '$PROGRAM_NAME connect' after manual recovery."
      return "$BROWSER_SESSION_BLOCK_RC"
    fi
    log "OpenConnect is running as pid $pid, but the ping target is not reachable; reconnecting."
    signal_tracked_openconnect HUP
    sleep 2
  fi

  if browser_session_blocked; then
    log "VPN reconnect is blocked by the browser session attempt limit; run '$PROGRAM_NAME connect' after manual recovery."
    return "$BROWSER_SESSION_BLOCK_RC"
  fi

  repair_stale_vpn_server_route

  local target
  target="$(resolve_ping_target || true)"
  if [[ -n "$target" ]] && ping_target_ok "$target"; then
    reset_browser_session_attempts "connectivity OK"
    log "Connectivity is already OK for $target; not starting a duplicate tunnel."
    return 0
  fi

  local json rc
  if json="$(run_cookie_helper)"; then
    :
  else
    rc=$?
    log "Cookie helper failed."
    block_browser_session_attempts_if_exhausted "cookie helper failed" || return "$?"
    return "$rc"
  fi

  if start_openconnect_with_cookie "$json"; then
    return 0
  fi
  block_browser_session_attempts_if_exhausted "OpenConnect failed after browser session attempt" || return "$?"
  if [[ "$COMMAND" != "connect" ]]; then
    log "Automatic connect will not force a second browser login in the same cycle."
    return 1
  fi

  log "First OpenConnect attempt failed; forcing browser relogin and retrying once."
  if json="$(run_cookie_helper --force-login)"; then
    :
  else
    rc=$?
    log "Forced browser relogin failed."
    block_browser_session_attempts_if_exhausted "forced browser relogin failed" || return "$?"
    return "$rc"
  fi
  if start_openconnect_with_cookie "$json"; then
    return 0
  fi
  rc=$?
  block_browser_session_attempts_if_exhausted "OpenConnect failed after forced browser session attempt" || return "$?"
  return "$rc"
}

command_disconnect() {
  require_root
  signal_tracked_openconnect HUP
  log "Disconnected tracked OpenConnect with SIGHUP."
}

command_logout() {
  require_root
  signal_tracked_openconnect TERM
  log "Terminated tracked OpenConnect with SIGTERM."
}

command_pause() {
  require_root
  set_auto_reconnect_paused "manual pause"
}

command_resume() {
  require_root
  clear_auto_reconnect_paused "manual resume"
}

command_disable() {
  require_root
  set_auto_reconnect_paused "manual disable"
  signal_tracked_openconnect HUP
  log "Disabled automatic reconnect and disconnected tracked OpenConnect."
}

command_enable() {
  require_root
  local old_command rc
  clear_auto_reconnect_paused "manual enable"
  old_command="$COMMAND"
  COMMAND=connect
  command_connect
  rc=$?
  COMMAND="$old_command"
  return "$rc"
}

command_status() {
  local target ping_status ip any cookie_summary
  target="$(resolve_ping_target || true)"
  if [[ -n "$target" ]] && ping_target_ok "$target"; then
    ping_status="OK ($target)"
  elif [[ -n "$target" ]]; then
    ping_status="FAIL ($target)"
  else
    ping_status="not checked"
  fi
  ip="$(vpn_internal_ip || true)"
  [[ -n "$ip" ]] || ip="not found"
  any="$(any_openconnect 2>/dev/null || true)"
  local server_info default_info server_route_status=""
  server_info="$(vpn_server_route_info || true)"
  if [[ -n "$server_info" ]]; then
    local -a server_parts default_parts
    server_parts=("${(@ps:|:)server_info}")
    default_info="$(default_route_info "${server_parts[3]:-}" || true)"
    default_parts=("${(@ps:|:)default_info}")
    if [[ -n "${default_parts[1]:-}" && "${server_parts[3]:-}" == "${default_parts[2]:-}" &&
          -n "${server_parts[2]:-}" && "${server_parts[2]:-}" != "${default_parts[1]:-}" ]]; then
      server_route_status=" stale; default gateway ${default_parts[1]}"
    fi
  fi

  print "Label:        $LABEL"
  print "Config:       $CONFIG_FILE"
  print "Tracked:      $(tracked_pid_status)"
  print "VPN IP:       $ip"
  print "Ping:         $ping_status"
  print "Auto:         $(auto_reconnect_status)"
  print "Browser tries: $(browser_session_budget_status)"
  [[ -n "$server_info" ]] && print "VPN gateway:  ${server_parts[1]:-unknown} via ${server_parts[2]:-unknown} on ${server_parts[3]:-unknown}${server_route_status}"
  print "OpenConnect processes:"
  if [[ -n "$any" ]]; then
    print -r -- "$any" | sed 's/^/  /'
  else
    print "  none"
  fi
  if [[ -f "$COOKIE_META_FILE" ]]; then
    cookie_summary="$("$NODE_BIN" -e '
      const fs = require("fs");
      const json = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
      const dsid = (json.cookieExpiries || []).find((cookie) => cookie.name === "DSID");
      console.log(`${json.ok ? "present" : "missing"}; checked=${json.checkedAt || "unknown"}; DSID expiry ${dsid ? dsid.expiresAt : "unknown"}`);
    ' "$COOKIE_META_FILE" 2>/dev/null || true)"
    print "Cookie:       ${cookie_summary:-metadata unreadable}"
  else
    print "Cookie:       no metadata"
  fi
}

command_doctor() {
  print "Root:         $(id -u)"
  print "Label:        $LABEL"
  print "User:         $USER_NAME ($USER_UID) home=$USER_HOME"
  print "GUI session:  $(user_gui_available && print available || print missing)"
  print "Email:        ${UC_DAVIS_EMAIL:-not configured}"
  print "Node:         ${NODE_BIN:-not found} $([[ -n "$NODE_BIN" && -x "$NODE_BIN" ]] && print OK || print missing)"
  print "Helper:       ${COOKIE_HELPER:-not configured} $([[ -n "$COOKIE_HELPER" && -f "$COOKIE_HELPER" ]] && print OK || print missing)"
  print "OpenConnect:  $OPENCONNECT_BIN $([[ -x "$OPENCONNECT_BIN" ]] && print OK || print missing)"
  print "vpnc-script:  $VPNC_SCRIPT $([[ -x "$VPNC_SCRIPT" ]] && print OK || print missing)"
  print "Ping target:  $(resolve_ping_target || true)"
  print "Auto:         $(auto_reconnect_status)"
  print "Browser tries: $(browser_session_budget_status)"
  local keychain_ok=1
  if [[ "$(id -u)" == "$USER_UID" ]]; then
    HOME="$USER_HOME" /usr/bin/security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$UC_DAVIS_EMAIL" >/dev/null 2>&1 && keychain_ok=0
  else
    /usr/bin/sudo -u "$USER_NAME" HOME="$USER_HOME" /usr/bin/security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$UC_DAVIS_EMAIL" >/dev/null 2>&1 && keychain_ok=0
  fi
  if [[ "$keychain_ok" == "0" ]]; then
    print "Keychain:     OK ($KEYCHAIN_SERVICE / $UC_DAVIS_EMAIL)"
  else
    print "Keychain:     missing or not accessible ($KEYCHAIN_SERVICE / $UC_DAVIS_EMAIL)"
  fi
}

monitor_once() {
  local target
  target="$(resolve_ping_target || true)"
  if [[ -n "$target" ]] && ping_target_ok "$target"; then
    log "Connectivity OK: $target"
    reset_browser_session_attempts "connectivity OK"
    return 0
  fi

  log "Connectivity failed: ${target:-unresolved target}"
  [[ "$AUTO_RECONNECT" == "1" ]] || return 1
  if auto_reconnect_paused; then
    log "Auto reconnect is paused; skipping reconnect."
    return 0
  fi
  if browser_session_blocked; then
    log "Auto reconnect is paused by the browser session attempt limit; run '$PROGRAM_NAME connect' after manual recovery."
    return "$BROWSER_SESSION_BLOCK_RC"
  fi

  if [[ -f "$PID_FILE" ]]; then
    local pid
    if pid="$(pid_from_file 2>/dev/null)" && pid_running "$pid"; then
      log "Tracked OpenConnect is running but ping failed; sending SIGHUP before reconnect."
      signal_tracked_openconnect HUP
    fi
  fi
  command_connect
}

command_once() {
  require_root
  monitor_once
}

command_run() {
  require_root
  acquire_run_lock
  setup_control_dir
  log "Starting daemon loop. interval=${CHECK_INTERVAL_SECONDS}s threshold=$FAILURE_THRESHOLD auto=$AUTO_RECONNECT connect_on_start=$CONNECT_ON_START"
  local failures=0
  local last_attempt=0
  local rc=0
  local blocked_logged=0

  process_control_requests

  if [[ "$CONNECT_ON_START" == "1" && ! -f "$AUTO_RECONNECT_PAUSE_FILE" ]]; then
    local target
    target="$(resolve_ping_target || true)"
    if [[ -z "$target" ]] || ! ping_target_ok "$target"; then
      log "Startup connectivity check failed; trying connect."
      if command_connect; then
        last_attempt="$(date +%s)"
      else
        rc=$?
        if (( rc == RETRY_WITHOUT_COOLDOWN_RC )); then
          log "Startup connect skipped full reconnect cooldown because GUI login is not ready."
        elif (( rc == BROWSER_SESSION_BLOCK_RC )); then
          log "Startup connect is paused by the browser session attempt limit."
        else
          last_attempt="$(date +%s)"
        fi
      fi
    fi
  fi

  while true; do
    local target now
    process_control_requests
    target="$(resolve_ping_target || true)"
    if [[ -n "$target" ]] && ping_target_ok "$target"; then
      failures=0
      blocked_logged=0
      reset_browser_session_attempts "connectivity OK"
    else
      if auto_reconnect_paused; then
        sleep_with_control "$CHECK_INTERVAL_SECONDS"
        continue
      fi
      if browser_session_blocked; then
        if (( blocked_logged == 0 )); then
          log "Auto reconnect is paused by the browser session attempt limit; run '$PROGRAM_NAME connect' after manual recovery."
          blocked_logged=1
        fi
        sleep_with_control "$CHECK_INTERVAL_SECONDS"
        continue
      fi
      blocked_logged=0
      failures=$((failures + 1))
      log "Monitor failure $failures/$FAILURE_THRESHOLD for ${target:-unresolved target}"
      now="$(date +%s)"
      if [[ "$AUTO_RECONNECT" == "1" ]] &&
         (( failures >= FAILURE_THRESHOLD )) &&
         (( now - last_attempt >= RECONNECT_COOLDOWN_SECONDS )); then
        if monitor_once; then
          last_attempt="$now"
          failures=0
        else
          rc=$?
          if (( rc == RETRY_WITHOUT_COOLDOWN_RC )); then
            log "Reconnect prerequisites are not ready; retrying on the next monitor cycle."
          elif (( rc == BROWSER_SESSION_BLOCK_RC )); then
            log "Auto reconnect is now paused by the browser session attempt limit."
          else
            last_attempt="$now"
            failures=0
          fi
        fi
      fi
    fi
    sleep_with_control "$CHECK_INTERVAL_SECONDS"
  done
}

if [[ "${UC_DAVIS_VPN_DAEMON_SOURCE_ONLY:-0}" == "1" ]]; then
  return 0 2>/dev/null || exit 0
fi

case "$COMMAND" in
  run) command_run ;;
  once) command_once ;;
  status) command_status ;;
  connect) command_connect ;;
  disconnect) command_disconnect ;;
  logout) command_logout ;;
  pause) command_pause ;;
  resume) command_resume ;;
  disable) command_disable ;;
  enable) command_enable ;;
  doctor) command_doctor ;;
  help) usage ;;
esac
