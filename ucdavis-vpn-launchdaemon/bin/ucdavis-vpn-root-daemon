#!/bin/zsh
set -euo pipefail

CONFIG_FILE="/Library/Application Support/ucdavis-vpn-daemon/config.env"
COMMAND="run"
PROGRAM_NAME="${0:t}"

while (( $# > 0 )); do
  case "$1" in
    --config)
      CONFIG_FILE="$2"
      shift 2
      ;;
    run|once|status|connect|disconnect|logout|doctor|pause|resume|disable|enable)
      COMMAND="$1"
      shift
      ;;
    -h|--help|help)
      COMMAND="help"
      shift
      ;;
    *)
      print -u2 "Unknown argument: $1"
      exit 2
      ;;
  esac
done

[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

LABEL="${LABEL:-local.ucdavis-openconnect-daemon}"

detect_console_user() {
  /usr/bin/stat -f %Su /dev/console 2>/dev/null
}

USER_NAME="${USER_NAME:-$(detect_console_user)}"
[[ "$USER_NAME" == "root" || -z "$USER_NAME" ]] && USER_NAME="${SUDO_USER:-}"
USER_UID="${USER_UID:-$(/usr/bin/id -u "$USER_NAME" 2>/dev/null || true)}"
USER_HOME="${USER_HOME:-$(/usr/bin/dscl . -read "/Users/$USER_NAME" NFSHomeDirectory 2>/dev/null | /usr/bin/awk '{print $2}' || true)}"
USER_HOME="${USER_HOME:-/Users/$USER_NAME}"

SERVER="${SERVER:-vpn.engineering.ucdavis.edu}"
UC_DAVIS_EMAIL="${UC_DAVIS_EMAIL:-}"
KEYCHAIN_SERVICE="${KEYCHAIN_SERVICE:-ucdavis-openconnect-vpn}"

SSH_HOST_ALIAS="${SSH_HOST_ALIAS:-}"
PING_TARGET="${PING_TARGET:-}"
PING_TARGETS="${PING_TARGETS:-}"
PING_COUNT="${PING_COUNT:-2}"
PING_TIMEOUT_MS="${PING_TIMEOUT_MS:-1500}"
HEALTH_CHECK_MODE="${HEALTH_CHECK_MODE:-auto}"
HEALTH_MIN_SUCCESS="${HEALTH_MIN_SUCCESS:-1}"
TCP_TARGET="${TCP_TARGET:-}"
TCP_TARGETS="${TCP_TARGETS:-}"
TCP_PORT="${TCP_PORT:-22}"
TCP_TIMEOUT_SECONDS="${TCP_TIMEOUT_SECONDS:-3}"
SSH_CONFIG_TIMEOUT_SECONDS="${SSH_CONFIG_TIMEOUT_SECONDS:-5}"
ROUTE_LOOKUP_TIMEOUT_SECONDS="${ROUTE_LOOKUP_TIMEOUT_SECONDS:-5}"
CHECK_INTERVAL_SECONDS="${CHECK_INTERVAL_SECONDS:-60}"
FAILURE_THRESHOLD="${FAILURE_THRESHOLD:-2}"
RECONNECT_COOLDOWN_SECONDS="${RECONNECT_COOLDOWN_SECONDS:-180}"
VERIFY_AFTER_CONNECT_SECONDS="${VERIFY_AFTER_CONNECT_SECONDS:-25}"
GUI_SESSION_WAIT_SECONDS="${GUI_SESSION_WAIT_SECONDS:-0}"
GUI_SESSION_POLL_SECONDS="${GUI_SESSION_POLL_SECONDS:-1}"
AUTO_RECONNECT="${AUTO_RECONNECT:-1}"
CONNECT_ON_START="${CONNECT_ON_START:-1}"
MAX_BROWSER_SESSION_ATTEMPTS="${MAX_BROWSER_SESSION_ATTEMPTS:-2}"
[[ "$MAX_BROWSER_SESSION_ATTEMPTS" == <-> ]] || MAX_BROWSER_SESSION_ATTEMPTS=2
PRESERVE_DEFAULT_ROUTE="${PRESERVE_DEFAULT_ROUTE:-1}"
DEFAULT_ROUTE_RESTORE_DELAY_SECONDS="${DEFAULT_ROUTE_RESTORE_DELAY_SECONDS:-2}"
[[ "$DEFAULT_ROUTE_RESTORE_DELAY_SECONDS" == <-> ]] || DEFAULT_ROUTE_RESTORE_DELAY_SECONDS=2
VPN_SPLIT_ROUTES="${VPN_SPLIT_ROUTES:-169.237.0.0/16 128.120.0.0/16}"
VPN_ROUTE_PING_TARGET="${VPN_ROUTE_PING_TARGET:-1}"
NETWORK_CHANGE_DETECT="${NETWORK_CHANGE_DETECT:-1}"
NETWORK_CHANGE_SETTLE_SECONDS="${NETWORK_CHANGE_SETTLE_SECONDS:-3}"
NETWORK_CHANGE_BYPASS_COOLDOWN="${NETWORK_CHANGE_BYPASS_COOLDOWN:-1}"
[[ "$HEALTH_MIN_SUCCESS" == <-> ]] || HEALTH_MIN_SUCCESS=1
(( HEALTH_MIN_SUCCESS > 0 )) || HEALTH_MIN_SUCCESS=1
[[ "$TCP_PORT" == <-> ]] || TCP_PORT=22
[[ "$TCP_TIMEOUT_SECONDS" == <-> ]] || TCP_TIMEOUT_SECONDS=3
[[ "$ROUTE_LOOKUP_TIMEOUT_SECONDS" == <-> ]] || ROUTE_LOOKUP_TIMEOUT_SECONDS=5
[[ "$NETWORK_CHANGE_SETTLE_SECONDS" == <-> ]] || NETWORK_CHANGE_SETTLE_SECONDS=3
[[ "$NETWORK_CHANGE_BYPASS_COOLDOWN" == <-> ]] || NETWORK_CHANGE_BYPASS_COOLDOWN=1

STATE_DIR="${STATE_DIR:-/var/run/ucdavis-openconnect-daemon}"
DB_DIR="${DB_DIR:-/var/db/ucdavis-openconnect-daemon}"
LOG_DIR="${LOG_DIR:-/var/log/ucdavis-openconnect-daemon}"
PID_FILE="${PID_FILE:-$STATE_DIR/openconnect.pid}"
COOKIE_META_FILE="${COOKIE_META_FILE:-$DB_DIR/cookie-meta.json}"
RUN_LOCK_DIR="${RUN_LOCK_DIR:-$DB_DIR/run.lock}"
PHYSICAL_DEFAULT_ROUTE_FILE="${PHYSICAL_DEFAULT_ROUTE_FILE:-$STATE_DIR/physical-default-route}"
NETWORK_SIGNATURE_FILE="${NETWORK_SIGNATURE_FILE:-$STATE_DIR/network-signature}"
NETWORK_CHANGE_PENDING_FILE="${NETWORK_CHANGE_PENDING_FILE:-$STATE_DIR/network-change.pending}"
BROWSER_SESSION_ATTEMPTS_FILE="${BROWSER_SESSION_ATTEMPTS_FILE:-$STATE_DIR/browser-session-attempts}"
BROWSER_SESSION_BLOCK_FILE="${BROWSER_SESSION_BLOCK_FILE:-$STATE_DIR/browser-session.blocked}"
AUTO_RECONNECT_PAUSE_FILE="${AUTO_RECONNECT_PAUSE_FILE:-$STATE_DIR/auto-reconnect.paused}"
CONTROL_DIR="${CONTROL_DIR:-$STATE_DIR/control}"
CONTROL_RESPONSE_DIR="${CONTROL_RESPONSE_DIR:-$STATE_DIR/control/responses}"
CONTROL_POLL_SECONDS="${CONTROL_POLL_SECONDS:-1}"
[[ "$CONTROL_POLL_SECONDS" == <-> ]] || CONTROL_POLL_SECONDS=1
(( CONTROL_POLL_SECONDS > 0 )) || CONTROL_POLL_SECONDS=1
DAEMON_LOG_FILE="${DAEMON_LOG_FILE:-$LOG_DIR/daemon.log}"
OPENCONNECT_LOG_FILE="${OPENCONNECT_LOG_FILE:-$LOG_DIR/openconnect.log}"

NODE_BIN="${NODE_BIN:-}"
COOKIE_HELPER="${COOKIE_HELPER:-}"
OPENCONNECT_BIN="${OPENCONNECT_BIN:-/opt/homebrew/bin/openconnect}"
VPNC_SCRIPT="${VPNC_SCRIPT:-/opt/homebrew/etc/vpnc/vpnc-script}"
OPENCONNECT_NO_DTLS="${OPENCONNECT_NO_DTLS:-1}"
OPENCONNECT_EXTRA_ARGS="${OPENCONNECT_EXTRA_ARGS:-}"

CHROME_PROFILE_DIR="${CHROME_PROFILE_DIR:-$USER_HOME/.local/state/ucdavis-vpn-chrome-profile}"
CHROME_CDP_PORT="${CHROME_CDP_PORT:-9223}"
CHROME_APP="${CHROME_APP:-Google Chrome}"
CLOSE_WINDOW_AFTER_COOKIE="${CLOSE_WINDOW_AFTER_COOKIE:-1}"
CLOSE_EXISTING_VPN_SESSIONS="${CLOSE_EXISTING_VPN_SESSIONS:-1}"

RETRY_WITHOUT_COOLDOWN_RC=75
BROWSER_SESSION_BLOCK_RC=76

mkdir -p "$STATE_DIR" "$DB_DIR" "$LOG_DIR" 2>/dev/null || true

find_node() {
  if [[ -n "$NODE_BIN" && -x "$NODE_BIN" ]]; then
    print -r -- "$NODE_BIN"
    return 0
  fi
  if [[ -x /opt/homebrew/bin/node ]]; then
    print -r -- /opt/homebrew/bin/node
    return 0
  fi
  if [[ -x /usr/local/bin/node ]]; then
    print -r -- /usr/local/bin/node
    return 0
  fi
  if command -v node >/dev/null 2>&1; then
    command -v node
    return 0
  fi
  if [[ -x /Applications/Codex.app/Contents/Resources/node ]]; then
    print -r -- /Applications/Codex.app/Contents/Resources/node
    return 0
  fi
  return 1
}

NODE_BIN="$(find_node || true)"

usage() {
  cat <<EOF
Usage: $PROGRAM_NAME [--config path] <command>

Commands:
  run          Long-running launchd mode.
  once         Run one monitor check.
  status       Print tracked OpenConnect, VPN IP, ping, and cookie metadata.
  connect      Connect now, using or refreshing the browser cookie.
  disconnect   Send SIGHUP to OpenConnect, preserving the web login session.
  logout       Send SIGTERM to OpenConnect, logging out the VPN session.
  pause        Pause automatic reconnect.
  resume       Resume automatic reconnect.
  disable      Pause automatic reconnect and disconnect the tunnel.
  enable       Resume automatic reconnect and connect now.
  doctor       Check dependencies and root/user context.

Config:
  $CONFIG_FILE
EOF
}

timestamp() {
  /bin/date "+%Y-%m-%d %H:%M:%S%z"
}

log() {
  local line="[$(timestamp)] $*"
  print -u2 -r -- "$line"
  print -r -- "$line" >> "$DAEMON_LOG_FILE"
}

require_root() {
  if [[ "$(id -u)" != "0" ]]; then
    print -u2 "This command must run as root."
    exit 1
  fi
}

pid_from_file() {
  [[ -f "$PID_FILE" ]] || return 1
  local pid
  pid="$(<"$PID_FILE")"
  [[ "$pid" == <-> ]] || return 1
  print -r -- "$pid"
}

pid_running() {
  local pid="$1"
  kill -0 "$pid" >/dev/null 2>&1 || ps -p "$pid" -o pid= >/dev/null 2>&1
}

launchd_tracked_pid() {
  /bin/launchctl print "system/$LABEL" 2>/dev/null | /usr/bin/awk '
    /^[[:space:]]*pid = [0-9]+$/ { print $3; exit }
  '
}

acquire_run_lock() {
  local self_pid="${ZSH_PID:-$$}"
  local lock_pid=""
  local tracked_pid=""
  while ! mkdir "$RUN_LOCK_DIR" 2>/dev/null; do
    lock_pid=""
    [[ -f "$RUN_LOCK_DIR/pid" ]] && lock_pid="$(<"$RUN_LOCK_DIR/pid")"
    if [[ "$lock_pid" == <-> ]] && pid_running "$lock_pid"; then
      tracked_pid="$(launchd_tracked_pid || true)"
      if [[ "$tracked_pid" == "$lock_pid" && "$self_pid" != "$tracked_pid" ]]; then
        log "Daemon singleton lock is held by launchd-tracked pid $lock_pid; exiting duplicate launcher pid $self_pid."
        exit 0
      fi
      log "Another daemon loop is active as pid $lock_pid; launcher pid $self_pid is standing by."
      while [[ "$lock_pid" == <-> ]] && pid_running "$lock_pid"; do
        sleep "$CHECK_INTERVAL_SECONDS"
        [[ -f "$RUN_LOCK_DIR/pid" ]] && lock_pid="$(<"$RUN_LOCK_DIR/pid")" || lock_pid=""
      done
      log "Daemon singleton lock holder exited; trying to acquire lock."
      rm -rf "$RUN_LOCK_DIR"
      continue
    fi
    log "Removing stale daemon singleton lock."
    rm -rf "$RUN_LOCK_DIR"
  done
  print -r -- "$self_pid" > "$RUN_LOCK_DIR/pid"
  log "Acquired daemon singleton lock as pid $self_pid."
}

tracked_pid_status() {
  local pid
  if pid="$(pid_from_file 2>/dev/null)" && pid_running "$pid"; then
    print -r -- "running (pid $pid)"
  else
    print -r -- "stopped"
  fi
}

resolve_ping_target() {
  if [[ -n "$PING_TARGET" ]]; then
    print -r -- "$PING_TARGET"
    return 0
  fi
  if [[ -n "$SSH_HOST_ALIAS" ]]; then
    local -a ssh_cmd
    ssh_cmd=(/usr/bin/ssh)
    [[ -f "$USER_HOME/.ssh/config" ]] && ssh_cmd+=(-F "$USER_HOME/.ssh/config")
    ssh_cmd+=(-G "$SSH_HOST_ALIAS")
    if [[ "$(id -u)" == "$USER_UID" ]]; then
      HOME="$USER_HOME" USER="$USER_NAME" LOGNAME="$USER_NAME" "${ssh_cmd[@]}" 2>/dev/null |
        /usr/bin/awk 'tolower($1) == "hostname" { print $2; exit }'
    else
      HOME="$USER_HOME" USER="$USER_NAME" LOGNAME="$USER_NAME" \
        /usr/bin/perl -e 'alarm shift; exec @ARGV' "$SSH_CONFIG_TIMEOUT_SECONDS" "${ssh_cmd[@]}" 2>/dev/null |
        /usr/bin/awk 'tolower($1) == "hostname" { print $2; exit }'
    fi
    return 0
  fi
}

ping_health_targets() {
  local target
  for target in ${=PING_TARGETS}; do
    [[ -n "$target" ]] && print -r -- "$target"
  done
  [[ -n "$PING_TARGET" ]] && print -r -- "$PING_TARGET"
  if [[ -z "$PING_TARGETS" && -z "$PING_TARGET" && -n "$SSH_HOST_ALIAS" ]]; then
    resolve_ping_target
  fi
}

network_service_for_device() {
  local device="$1"
  /usr/sbin/networksetup -listallhardwareports 2>/dev/null | /usr/bin/awk -v device="$device" '
    /^Hardware Port:/ {
      service=$0
      sub(/^Hardware Port: /, "", service)
    }
    /^Device:/ && $2 == device {
      print service
      exit
    }
  '
}

router_for_device() {
  local device="$1"
  local service
  service="$(network_service_for_device "$device" || true)"
  [[ -n "$service" ]] || return 1
  /usr/sbin/networksetup -getinfo "$service" 2>/dev/null | /usr/bin/awk -F': ' '
    $1 == "Router" && $2 != "" && $2 != "none" {
      print $2
      exit
    }
  '
}

route_get() {
  local destination="$1"
  [[ -n "$destination" ]] || return 1
  /usr/bin/perl -e 'alarm shift; exec @ARGV' \
    "$ROUTE_LOOKUP_TIMEOUT_SECONDS" /sbin/route -n get "$destination" 2>/dev/null
}

default_route_info() {
  local fallback_iface="${1:-}"
  local route_info
  route_info="$(route_get default | /usr/bin/awk '
    /gateway:/ { gateway=$2 }
    /interface:/ { iface=$2 }
    END { if (gateway || iface) print gateway "|" iface }
  ' || true)"
  if [[ -n "$route_info" ]]; then
    print -r -- "$route_info"
    return 0
  fi

  local iface="$fallback_iface"
  if [[ -z "$iface" ]]; then
    iface="$(/usr/sbin/scutil --nwi 2>/dev/null | /usr/bin/awk '
      /IPv4 network interface information/ { in_ipv4=1; next }
      /IPv6 network interface information/ { in_ipv4=0 }
      in_ipv4 && /^[[:space:]]+[[:alnum:]]+[[:space:]]*:/ {
        gsub(":", "", $1)
        print $1
        exit
      }
    ')"
  fi
  [[ -n "$iface" ]] || return 1

  local router
  router="$(router_for_device "$iface" || true)"
  [[ -n "$router" ]] || return 1
  print -r -- "$router|$iface"
}

is_tunnel_iface() {
  local iface="$1"
  [[ "$iface" == utun* || "$iface" == tun* || "$iface" == ppp* ]]
}

physical_route_from_interface() {
  local iface="$1"
  [[ -n "$iface" ]] || return 1
  is_tunnel_iface "$iface" && return 1

  local router
  router="$(router_for_device "$iface" || true)"
  [[ -n "$router" ]] || return 1
  print -r -- "$router|$iface"
}

primary_physical_default_route_info() {
  local info
  info="$(default_route_info || true)"
  if [[ -n "$info" ]]; then
    local -a parts
    parts=("${(@ps:|:)info}")
    if [[ -n "${parts[1]:-}" && -n "${parts[2]:-}" ]] && ! is_tunnel_iface "${parts[2]:-}"; then
      print -r -- "$info"
      return 0
    fi
  fi

  local iface
  iface="$(/usr/sbin/scutil --nwi 2>/dev/null | /usr/bin/awk '
    /IPv4 network interface information/ { in_ipv4=1; next }
    /IPv6 network interface information/ { in_ipv4=0 }
    in_ipv4 && /^[[:space:]]+[[:alnum:]]+[[:space:]]*:/ {
      gsub(":", "", $1)
      if ($1 !~ /^(utun|tun|ppp)/) {
        print $1
        exit
      }
    }
  ')"
  physical_route_from_interface "$iface"
}

wifi_network_name_for_device() {
  local device="$1"
  [[ -n "$device" ]] || return 1
  /usr/sbin/networksetup -getairportnetwork "$device" 2>/dev/null |
    /usr/bin/sed -n 's/^Current Wi-Fi Network: //p'
}

network_signature() {
  local info iface ssid
  info="$(primary_physical_default_route_info || default_route_info || true)"
  [[ -n "$info" ]] || info="none|none"
  local -a parts
  parts=("${(@ps:|:)info}")
  iface="${parts[2]:-}"
  ssid=""
  if [[ -n "$iface" ]]; then
    ssid="$(wifi_network_name_for_device "$iface" || true)"
  fi
  print -r -- "$info|ssid=${ssid:-unknown}"
}

initialize_network_signature() {
  [[ "$NETWORK_CHANGE_DETECT" == "1" ]] || return 0
  mkdir -p "$STATE_DIR" 2>/dev/null || true
  network_signature > "$NETWORK_SIGNATURE_FILE" 2>/dev/null || true
  rm -f "$NETWORK_CHANGE_PENDING_FILE" 2>/dev/null || true
}

mark_network_change_pending() {
  local old_signature="$1"
  local new_signature="$2"
  {
    print "changed_at=$(timestamp)"
    print "old=$old_signature"
    print "new=$new_signature"
  } > "$NETWORK_CHANGE_PENDING_FILE"
}

detect_network_change() {
  [[ "$NETWORK_CHANGE_DETECT" == "1" ]] || return 1
  local old_signature new_signature
  new_signature="$(network_signature || true)"
  [[ -n "$new_signature" ]] || new_signature="none|none|ssid=unknown"

  if [[ ! -f "$NETWORK_SIGNATURE_FILE" ]]; then
    mkdir -p "$STATE_DIR" 2>/dev/null || true
    print -r -- "$new_signature" > "$NETWORK_SIGNATURE_FILE"
    return 1
  fi

  old_signature="$(<"$NETWORK_SIGNATURE_FILE")"
  if [[ "$new_signature" == "$old_signature" ]]; then
    return 1
  fi

  print -r -- "$new_signature" > "$NETWORK_SIGNATURE_FILE"
  log "Network changed: ${old_signature:-unknown} -> ${new_signature:-unknown}."
  mark_network_change_pending "${old_signature:-unknown}" "$new_signature"
  return 0
}

consume_network_change_pending() {
  [[ -f "$NETWORK_CHANGE_PENDING_FILE" ]] || return 1
  local old_signature new_signature
  old_signature="$(/usr/bin/awk -F= '$1 == "old" { print substr($0, 5); exit }' "$NETWORK_CHANGE_PENDING_FILE" 2>/dev/null || true)"
  new_signature="$(/usr/bin/awk -F= '$1 == "new" { print substr($0, 5); exit }' "$NETWORK_CHANGE_PENDING_FILE" 2>/dev/null || true)"
  rm -f "$NETWORK_CHANGE_PENDING_FILE"
  print -r -- "${old_signature:-unknown} -> ${new_signature:-unknown}"
}

remember_physical_default_route() {
  [[ "$PRESERVE_DEFAULT_ROUTE" == "1" ]] || return 0
  local info="${1:-}"
  [[ -n "$info" ]] || info="$(primary_physical_default_route_info || true)"
  [[ -n "$info" ]] || return 1

  local -a parts
  parts=("${(@ps:|:)info}")
  [[ -n "${parts[1]:-}" && -n "${parts[2]:-}" ]] || return 1
  is_tunnel_iface "${parts[2]:-}" && return 1

  mkdir -p "$STATE_DIR" 2>/dev/null || true
  print -r -- "$info" > "$PHYSICAL_DEFAULT_ROUTE_FILE"
}

saved_physical_default_route_info() {
  local info
  if [[ -f "$PHYSICAL_DEFAULT_ROUTE_FILE" ]]; then
    info="$(<"$PHYSICAL_DEFAULT_ROUTE_FILE")"
    local -a parts
    parts=("${(@ps:|:)info}")
    if [[ -n "${parts[1]:-}" && -n "${parts[2]:-}" ]] && ! is_tunnel_iface "${parts[2]:-}"; then
      print -r -- "$info"
      return 0
    fi
  fi
  primary_physical_default_route_info
}

restore_default_route() {
  [[ "$PRESERVE_DEFAULT_ROUTE" == "1" ]] || return 0
  local info="${1:-}"
  local reason="${2:-route guard}"
  [[ -n "$info" ]] || info="$(saved_physical_default_route_info || true)"
  [[ -n "$info" ]] || return 1

  local -a parts current_parts
  parts=("${(@ps:|:)info}")
  local gateway="${parts[1]:-}"
  local iface="${parts[2]:-}"
  [[ -n "$gateway" && -n "$iface" ]] || return 1
  is_tunnel_iface "$iface" && return 1

  local current
  current="$(default_route_info || true)"
  current_parts=("${(@ps:|:)current}")
  local current_gateway="${current_parts[1]:-}"
  local current_iface="${current_parts[2]:-}"

  if [[ "$current_gateway" == "$gateway" && "$current_iface" == "$iface" ]]; then
    remember_physical_default_route "$info" >/dev/null 2>&1 || true
    return 0
  fi

  if [[ -z "$current" || -z "$current_iface" || "$current_gateway" != "$gateway" || "$current_iface" != "$iface" ]]; then
    log "Restoring physical default route via $gateway on $iface ($reason; current ${current_gateway:-none} on ${current_iface:-none})."
    /sbin/route -n change default "$gateway" >/dev/null 2>&1 ||
      {
        /sbin/route -n delete default >/dev/null 2>&1 || true
        /sbin/route -n add default "$gateway" >/dev/null 2>&1 ||
          /sbin/route -n change default "$gateway" >/dev/null 2>&1 ||
          true
      }
    remember_physical_default_route "$info" >/dev/null 2>&1 || true
  fi
}

route_guard_tick() {
  [[ "$PRESERVE_DEFAULT_ROUTE" == "1" ]] || return 0

  repair_stale_vpn_server_route

  local current
  current="$(default_route_info || true)"
  if [[ -n "$current" ]]; then
    local -a parts
    parts=("${(@ps:|:)current}")
    local iface="${parts[2]:-}"
    if [[ -n "$iface" ]] && ! is_tunnel_iface "$iface"; then
      remember_physical_default_route "$current" >/dev/null 2>&1 || true
      ensure_vpn_split_routes "monitor"
      return 0
    fi
  fi

  restore_default_route "" "monitor detected VPN-owned or missing default route" >/dev/null 2>&1 || true
  ensure_vpn_split_routes "monitor"
}

route_uses_iface() {
  local destination="$1"
  local expected_iface="$2"
  [[ -n "$destination" && -n "$expected_iface" ]] || return 1
  route_get "$destination" | /usr/bin/awk -v expected="$expected_iface" '
    /interface:/ { iface=$2 }
    END { exit iface == expected ? 0 : 1 }
  '
}

add_net_route_via_vpn() {
  local route="$1"
  local iface="$2"
  local context="${3:-route guard}"
  [[ -n "$route" && -n "$iface" ]] || return 0

  local probe="${route%%/*}"
  if route_uses_iface "$probe" "$iface"; then
    return 0
  fi

  log "Routing VPN split net $route via $iface ($context)."
  /sbin/route -n add -net "$route" -interface "$iface" >/dev/null 2>&1 ||
    /sbin/route -n change -net "$route" -interface "$iface" >/dev/null 2>&1 ||
    true
}

add_host_route_via_vpn() {
  local host="$1"
  local iface="$2"
  local context="${3:-route guard}"
  [[ -n "$host" && -n "$iface" ]] || return 0

  if route_uses_iface "$host" "$iface"; then
    return 0
  fi

  log "Routing VPN target host $host via $iface ($context)."
  /sbin/route -n add -host "$host" -interface "$iface" >/dev/null 2>&1 ||
    /sbin/route -n change -host "$host" -interface "$iface" >/dev/null 2>&1 ||
    true
}

ensure_vpn_server_physical_route() {
  local context="${1:-route guard}"
  local server_info physical_info
  server_info="$(vpn_server_route_info || true)"
  physical_info="$(saved_physical_default_route_info || true)"
  [[ -n "$server_info" && -n "$physical_info" ]] || return 0

  local -a server_parts physical_parts
  server_parts=("${(@ps:|:)server_info}")
  physical_parts=("${(@ps:|:)physical_info}")
  local server_ip="${server_parts[1]:-}"
  local physical_gateway="${physical_parts[1]:-}"
  local physical_iface="${physical_parts[2]:-}"
  [[ -n "$server_ip" && -n "$physical_gateway" && -n "$physical_iface" ]] || return 0

  if [[ "${server_parts[2]:-}" == "$physical_gateway" && "${server_parts[3]:-}" == "$physical_iface" ]]; then
    return 0
  fi

  log "Keeping VPN gateway $server_ip via $physical_gateway on $physical_iface ($context)."
  /sbin/route -n add -host "$server_ip" "$physical_gateway" >/dev/null 2>&1 ||
    /sbin/route -n change -host "$server_ip" "$physical_gateway" >/dev/null 2>&1 ||
    true
}

ensure_vpn_split_routes() {
  local context="${1:-route guard}"
  local vpn_info
  vpn_info="$(vpn_internal_ip || true)"
  [[ -n "$vpn_info" ]] || return 0

  local -a vpn_parts
  vpn_parts=("${(@s: :)vpn_info}")
  local vpn_iface="${vpn_parts[1]:-}"
  [[ -n "$vpn_iface" ]] || return 0

  ensure_vpn_server_physical_route "$context"

  local route
  for route in ${=VPN_SPLIT_ROUTES}; do
    add_net_route_via_vpn "$route" "$vpn_iface" "$context"
  done

  if [[ "$VPN_ROUTE_PING_TARGET" == "1" ]]; then
    local target server_info server_ip
    server_info="$(vpn_server_route_info || true)"
    local -a server_parts
    server_parts=("${(@ps:|:)server_info}")
    server_ip="${server_parts[1]:-}"
    while IFS= read -r target; do
      if [[ -n "$target" && "$target" != "$server_ip" ]]; then
        add_host_route_via_vpn "$target" "$vpn_iface" "$context"
      fi
    done <<< "$(health_check_route_targets || true)"
  fi
}

vpn_server_route_info() {
  route_get "$SERVER" | /usr/bin/awk '
    /route to:/ { route=$3 }
    /gateway:/ { gateway=$2 }
    /interface:/ { iface=$2 }
    END { if (route || gateway || iface) print route "|" gateway "|" iface }
  '
}

repair_stale_vpn_server_route() {
  local server_info
  server_info="$(vpn_server_route_info || true)"
  [[ -n "$server_info" ]] || return 0

  local -a server_parts default_parts
  server_parts=("${(@ps:|:)server_info}")

  local server_ip="${server_parts[1]:-}"
  local server_gateway="${server_parts[2]:-}"
  local server_iface="${server_parts[3]:-}"
  local default_info
  default_info="$(default_route_info "$server_iface" || true)"
  [[ -n "$default_info" ]] || return 0

  default_parts=("${(@ps:|:)default_info}")
  local default_gateway="${default_parts[1]:-}"
  local default_iface="${default_parts[2]:-}"

  if ! route_get default >/dev/null 2>&1 && [[ -n "$default_gateway" ]]; then
    log "Default route is missing; restoring default via $default_gateway on $default_iface."
    /sbin/route -n add default "$default_gateway" >/dev/null 2>&1 ||
      /sbin/route -n change default "$default_gateway" >/dev/null 2>&1 ||
      true
  fi

  if [[ -n "$server_ip" && -n "$server_gateway" && -n "$default_gateway" &&
        "$server_iface" == "$default_iface" && "$server_gateway" != "$default_gateway" ]]; then
    log "VPN server route looks stale: $server_ip via $server_gateway on $server_iface; default is $default_gateway. Deleting route before reconnect."
    /sbin/route -n delete "$server_ip" >/dev/null 2>&1 || true
  fi
}

ping_target_ok() {
  local target="$1"
  [[ -n "$target" ]] || return 1
  /sbin/ping -q -c "$PING_COUNT" -W "$PING_TIMEOUT_MS" "$target" >/dev/null 2>&1
}

split_tcp_target() {
  local value="$1"
  local default_port="${2:-$TCP_PORT}"
  [[ -n "$value" ]] || return 1
  if [[ "$value" == *:* ]]; then
    print -r -- "${value%:*}|${value##*:}"
  else
    print -r -- "$value|$default_port"
  fi
}

resolve_tcp_target() {
  local host
  if [[ -n "$TCP_TARGET" ]]; then
    split_tcp_target "$TCP_TARGET" "$TCP_PORT"
    return 0
  fi
  host="$(resolve_ping_target || true)"
  [[ -n "$host" ]] || return 1
  split_tcp_target "$host" "$TCP_PORT"
}

tcp_health_targets() {
  local target host
  for target in ${=TCP_TARGETS}; do
    [[ -n "$target" ]] && split_tcp_target "$target" "$TCP_PORT"
  done
  [[ -n "$TCP_TARGET" ]] && split_tcp_target "$TCP_TARGET" "$TCP_PORT"
  if [[ -z "$TCP_TARGETS" && -z "$TCP_TARGET" ]]; then
    host="$(resolve_ping_target || true)"
    [[ -n "$host" ]] && split_tcp_target "$host" "$TCP_PORT"
  fi
}

tcp_target_ok() {
  local info="$1"
  local -a parts
  parts=("${(@ps:|:)info}")
  local host="${parts[1]:-}"
  local port="${parts[2]:-$TCP_PORT}"
  [[ -n "$host" && "$port" == <-> ]] || return 1
  /usr/bin/nc -G "$TCP_TIMEOUT_SECONDS" -z "$host" "$port" >/dev/null 2>&1
}

resolved_health_check_mode() {
  case "$HEALTH_CHECK_MODE" in
    ping|tcp|tunnel)
      print -r -- "$HEALTH_CHECK_MODE"
      ;;
    auto|"")
      if [[ -n "$TCP_TARGETS" || -n "$TCP_TARGET" ]]; then
        print tcp
      elif [[ -n "$PING_TARGETS" || -n "$PING_TARGET" || -n "$SSH_HOST_ALIAS" ]]; then
        print ping
      else
        print tunnel
      fi
      ;;
    *)
      print tunnel
      ;;
  esac
}

health_check_route_target() {
  local mode info
  mode="$(resolved_health_check_mode)"
  case "$mode" in
    ping)
      ping_health_targets | /usr/bin/sed -n '1p'
      ;;
    tcp)
      info="$(tcp_health_targets | /usr/bin/sed -n '1p' || true)"
      [[ -n "$info" ]] || return 1
      print -r -- "${info%%|*}"
      ;;
  esac
}

health_check_route_targets() {
  local mode info
  mode="$(resolved_health_check_mode)"
  case "$mode" in
    ping)
      ping_health_targets
      ;;
    tcp)
      while IFS= read -r info; do
        [[ -n "$info" ]] && print -r -- "${info%%|*}"
      done <<< "$(tcp_health_targets)"
      ;;
  esac
}

health_check_description() {
  local mode targets info
  mode="$(resolved_health_check_mode)"
  case "$mode" in
    ping)
      targets="$(ping_health_targets | paste -sd, - 2>/dev/null || true)"
      print -r -- "ping ${targets:-unresolved} (min $HEALTH_MIN_SUCCESS)"
      ;;
    tcp)
      targets="$(tcp_health_targets | while IFS= read -r info; do
        local -a parts
        parts=("${(@ps:|:)info}")
        print -r -- "${parts[1]:-unresolved}:${parts[2]:-$TCP_PORT}"
      done | paste -sd, - 2>/dev/null || true)"
      print -r -- "tcp ${targets:-unresolved} (min $HEALTH_MIN_SUCCESS)"
      ;;
    *)
      print -r -- "tunnel"
      ;;
  esac
}

health_check_ok() {
  local mode target info successes=0 total=0
  mode="$(resolved_health_check_mode)"
  case "$mode" in
    ping)
      while IFS= read -r target; do
        [[ -n "$target" ]] || continue
        total=$((total + 1))
        ping_target_ok "$target" && successes=$((successes + 1))
        (( successes >= HEALTH_MIN_SUCCESS )) && return 0
      done <<< "$(ping_health_targets)"
      (( total > 0 && successes >= HEALTH_MIN_SUCCESS ))
      ;;
    tcp)
      while IFS= read -r info; do
        [[ -n "$info" ]] || continue
        total=$((total + 1))
        tcp_target_ok "$info" && successes=$((successes + 1))
        (( successes >= HEALTH_MIN_SUCCESS )) && return 0
      done <<< "$(tcp_health_targets)"
      (( total > 0 && successes >= HEALTH_MIN_SUCCESS ))
      ;;
    tunnel)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

vpn_session_ok() {
  local pid
  pid="$(pid_from_file 2>/dev/null)" && pid_running "$pid" || return 1
  [[ -n "$(vpn_internal_ip || true)" ]] || return 1
  health_check_ok
}

vpn_internal_ip() {
  /sbin/ifconfig | /usr/bin/awk '
    /^utun[0-9]+:/ { iface=$1; sub(":", "", iface) }
    $1 == "inet" && $2 ~ /^172\.2[0-9]\./ { print iface " " $2; exit }
  '
}

any_openconnect() {
  /bin/ps -axo user=,pid=,command= |
    /usr/bin/awk '
      /(^|[[:space:]])([^[:space:]]*\/)?[o]penconnect([[:space:]]|$)/ {
        print
        found=1
      }
      END { exit found ? 0 : 1 }
    '
}

user_gui_available() {
  /bin/launchctl print "gui/$USER_UID" >/dev/null 2>&1
}

setup_control_dir() {
  require_root
  mkdir -p "$CONTROL_DIR" "$CONTROL_RESPONSE_DIR"
  chown "$USER_NAME" "$CONTROL_DIR" "$CONTROL_RESPONSE_DIR" >/dev/null 2>&1 || true
  chmod 0700 "$CONTROL_DIR" "$CONTROL_RESPONSE_DIR" >/dev/null 2>&1 || true
}

auto_reconnect_paused() {
  [[ -f "$AUTO_RECONNECT_PAUSE_FILE" ]]
}

set_auto_reconnect_paused() {
  mkdir -p "$STATE_DIR" 2>/dev/null || true
  {
    print "paused_at=$(timestamp)"
    print "reason=${1:-manual pause}"
  } > "$AUTO_RECONNECT_PAUSE_FILE"
  log "Automatic reconnect paused: ${1:-manual pause}."
}

clear_auto_reconnect_paused() {
  local reason="${1:-manual resume}"
  if [[ -f "$AUTO_RECONNECT_PAUSE_FILE" ]]; then
    rm -f "$AUTO_RECONNECT_PAUSE_FILE"
    log "Automatic reconnect resumed: $reason."
  fi
}

auto_reconnect_status() {
  local reason
  if auto_reconnect_paused; then
    reason="$(/usr/bin/awk -F= '$1 == "reason" { print $2; exit }' "$AUTO_RECONNECT_PAUSE_FILE" 2>/dev/null || true)"
    print "paused${reason:+ ($reason)}"
  else
    print "$([[ "$AUTO_RECONNECT" == "1" ]] && print active || print disabled)"
  fi
}

browser_session_attempt_count() {
  local count=0
  if [[ -f "$BROWSER_SESSION_ATTEMPTS_FILE" ]]; then
    count="$(<"$BROWSER_SESSION_ATTEMPTS_FILE")"
  fi
  [[ "$count" == <-> ]] || count=0
  print -r -- "$count"
}

browser_session_blocked() {
  (( MAX_BROWSER_SESSION_ATTEMPTS > 0 )) && [[ -f "$BROWSER_SESSION_BLOCK_FILE" ]]
}

browser_session_budget_exhausted() {
  (( MAX_BROWSER_SESSION_ATTEMPTS > 0 )) &&
    (( $(browser_session_attempt_count) >= MAX_BROWSER_SESSION_ATTEMPTS ))
}

block_browser_session_attempts() {
  local count reason
  count="$(browser_session_attempt_count)"
  reason="${1:-browser session attempt limit reached}"
  {
    print "blocked_at=$(timestamp)"
    print "attempts=$count"
    print "max=$MAX_BROWSER_SESSION_ATTEMPTS"
    print "reason=$reason"
  } > "$BROWSER_SESSION_BLOCK_FILE"
  log "Browser session attempts are blocked after $count/$MAX_BROWSER_SESSION_ATTEMPTS attempts; run '$PROGRAM_NAME connect' after manual recovery."
}

block_browser_session_attempts_if_exhausted() {
  local reason="${1:-browser session attempt limit reached}"
  if ! browser_session_blocked && browser_session_budget_exhausted; then
    block_browser_session_attempts "$reason"
    return "$BROWSER_SESSION_BLOCK_RC"
  fi
  browser_session_blocked && return "$BROWSER_SESSION_BLOCK_RC"
  return 0
}

reset_browser_session_attempts() {
  local reason="${1:-manual connect}"
  if [[ -f "$BROWSER_SESSION_ATTEMPTS_FILE" || -f "$BROWSER_SESSION_BLOCK_FILE" ]]; then
    rm -f "$BROWSER_SESSION_ATTEMPTS_FILE" "$BROWSER_SESSION_BLOCK_FILE"
    log "Reset browser session attempt state: $reason."
  fi
  return 0
}

record_browser_session_attempt() {
  local mode="$1"
  local count next
  (( MAX_BROWSER_SESSION_ATTEMPTS > 0 )) || return 0
  if browser_session_blocked; then
    log "Browser session attempts are currently blocked; run '$PROGRAM_NAME connect' after manual recovery."
    return "$BROWSER_SESSION_BLOCK_RC"
  fi
  count="$(browser_session_attempt_count)"
  if (( count >= MAX_BROWSER_SESSION_ATTEMPTS )); then
    block_browser_session_attempts "attempt limit reached before $mode"
    return "$BROWSER_SESSION_BLOCK_RC"
  fi
  next=$(( count + 1 ))
  print -r -- "$next" > "$BROWSER_SESSION_ATTEMPTS_FILE"
  log "Browser session attempt $next/$MAX_BROWSER_SESSION_ATTEMPTS ($mode)."
  if (( next >= MAX_BROWSER_SESSION_ATTEMPTS )); then
    log "This is the last automatic browser session attempt before manual connect is required."
  fi
  return 0
}

browser_session_budget_status() {
  local count block_summary
  count="$(browser_session_attempt_count)"
  if (( MAX_BROWSER_SESSION_ATTEMPTS <= 0 )); then
    print "unlimited"
    return 0
  fi
  if browser_session_blocked; then
    block_summary="$(/usr/bin/awk -F= '
      $1 == "blocked_at" { blocked_at=$2 }
      $1 == "reason" { reason=$2 }
      END {
        if (blocked_at || reason) print "blocked since " blocked_at (reason ? "; " reason : "")
      }
    ' "$BROWSER_SESSION_BLOCK_FILE" 2>/dev/null || true)"
    print "blocked ($count/$MAX_BROWSER_SESSION_ATTEMPTS${block_summary:+; $block_summary})"
  else
    print "$count/$MAX_BROWSER_SESSION_ATTEMPTS"
  fi
}

control_request_field() {
  local file="$1"
  local key="$2"
  /usr/bin/awk -F= -v key="$key" '$1 == key { print substr($0, length(key) + 2); exit }' "$file" 2>/dev/null
}

write_control_response() {
  local id="$1"
  local code="$2"
  local output="$3"
  local tmp="$CONTROL_RESPONSE_DIR/$id.response.tmp.$$"
  local response="$CONTROL_RESPONSE_DIR/$id.response"
  {
    print "exit=$code"
    print "output<<EOF"
    print -r -- "$output"
    print "EOF"
  } > "$tmp"
  chown "$USER_NAME" "$tmp" >/dev/null 2>&1 || true
  chmod 0600 "$tmp" >/dev/null 2>&1 || true
  mv "$tmp" "$response"
}

handle_control_command() {
  local command="$1"
  local old_command rc
  case "$command" in
    status)
      command_status
      ;;
    connect)
      clear_auto_reconnect_paused "manual connect"
      old_command="$COMMAND"
      COMMAND=connect
      command_connect
      rc=$?
      COMMAND="$old_command"
      return "$rc"
      ;;
    disconnect)
      command_disconnect
      ;;
    logout)
      command_logout
      ;;
    pause)
      command_pause
      ;;
    resume)
      command_resume
      ;;
    disable|off)
      command_disable
      ;;
    enable|on)
      command_enable
      ;;
    once)
      monitor_once
      ;;
    *)
      print -u2 "Unsupported control command: $command"
      return 2
      ;;
  esac
}

process_control_requests() {
  emulate -L zsh
  setopt null_glob
  local request owner id command output rc
  for request in "$CONTROL_DIR"/*.request; do
    [[ -f "$request" ]] || continue
    owner="$(/usr/bin/stat -f %u "$request" 2>/dev/null || true)"
    if [[ -n "$USER_UID" && "$owner" != "$USER_UID" ]]; then
      log "Ignoring control request not owned by uid $USER_UID: $request"
      rm -f "$request"
      continue
    fi
    id="${request:t:r}"
    command="$(control_request_field "$request" command)"
    rm -f "$request"
    if output="$(handle_control_command "$command" 2>&1)"; then
      rc=0
    else
      rc=$?
    fi
    write_control_response "$id" "$rc" "$output"
  done
}

sleep_with_control() {
  local remaining="$1"
  local slice
  while (( remaining > 0 )); do
    process_control_requests
    if [[ -f "$NETWORK_CHANGE_PENDING_FILE" ]] || detect_network_change >/dev/null 2>&1; then
      return 0
    fi
    slice="$CONTROL_POLL_SECONDS"
    (( slice > remaining )) && slice="$remaining"
    sleep "$slice"
    remaining=$(( remaining - slice ))
  done
}

wait_for_user_gui() {
  local start now elapsed
  user_gui_available && return 0

  start="$(date +%s)"
  if (( GUI_SESSION_WAIT_SECONDS > 0 )); then
    log "Waiting up to ${GUI_SESSION_WAIT_SECONDS}s for GUI session gui/$USER_UID before browser login."
  else
    log "Waiting for GUI session gui/$USER_UID before browser login."
  fi

  while true; do
    sleep "$GUI_SESSION_POLL_SECONDS"
    if user_gui_available; then
      now="$(date +%s)"
      elapsed=$(( now - start ))
      log "GUI session gui/$USER_UID is available after ${elapsed}s; starting browser login helper."
      return 0
    fi
    (( GUI_SESSION_WAIT_SECONDS <= 0 )) && continue
    now="$(date +%s)"
    (( now - start >= GUI_SESSION_WAIT_SECONDS )) && return 1
  done
}

run_cookie_helper() {
  local helper_output helper_rc
  [[ -n "$USER_NAME" && -n "$USER_UID" && -n "$USER_HOME" ]] || {
    log "USER_NAME, USER_UID, and USER_HOME must be configured."
    return 1
  }
  [[ -n "$UC_DAVIS_EMAIL" ]] || {
    log "UC_DAVIS_EMAIL must be configured."
    return 1
  }
  [[ -n "$COOKIE_HELPER" ]] || {
    log "COOKIE_HELPER must be configured."
    return 1
  }
  wait_for_user_gui || {
    log "GUI session gui/$USER_UID is not available after ${GUI_SESSION_WAIT_SECONDS}s; will retry without reconnect cooldown."
    return "$RETRY_WITHOUT_COOLDOWN_RC"
  }
  [[ -x "$NODE_BIN" ]] || {
    log "Node binary not executable: $NODE_BIN"
    return 1
  }
  [[ -f "$COOKIE_HELPER" ]] || {
    log "Cookie helper missing: $COOKIE_HELPER"
    return 1
  }

  local mode="reuse existing session"
  [[ " $* " == *" --force-login "* ]] && mode="force browser login"
  local attempt_rc
  record_browser_session_attempt "$mode" || {
    attempt_rc=$?
    return "$attempt_rc"
  }

  helper_output="$STATE_DIR/cookie-helper-output.$$"
  rm -f "$helper_output"
  /bin/launchctl asuser "$USER_UID" /usr/bin/sudo -u "$USER_NAME" \
    /usr/bin/env \
      HOME="$USER_HOME" \
      USER="$USER_NAME" \
      LOGNAME="$USER_NAME" \
      PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin" \
      UCD_VPN_SERVER="$SERVER" \
      UCD_VPN_EMAIL="$UC_DAVIS_EMAIL" \
      UCD_VPN_KEYCHAIN_SERVICE="$KEYCHAIN_SERVICE" \
      UCD_VPN_PROFILE_DIR="$CHROME_PROFILE_DIR" \
      UCD_VPN_CDP_PORT="$CHROME_CDP_PORT" \
      UCD_VPN_CHROME_APP="$CHROME_APP" \
      UCD_VPN_CLOSE_WINDOW_AFTER_COOKIE="$CLOSE_WINDOW_AFTER_COOKIE" \
      UCD_VPN_CLOSE_EXISTING_SESSIONS="$CLOSE_EXISTING_VPN_SESSIONS" \
      "$NODE_BIN" "$COOKIE_HELPER" --json "$@" > "$helper_output"
  helper_rc=$?
  if (( helper_rc != 0 )); then
    rm -f "$helper_output"
    return "$helper_rc"
  fi
  if [[ ! -s "$helper_output" ]]; then
    log "Cookie helper completed without JSON output."
    rm -f "$helper_output"
    return 1
  fi
  cat "$helper_output"
  rm -f "$helper_output"
}

json_field() {
  local field="$1"
  "$NODE_BIN" -e '
    const field = process.argv[1];
    let data = "";
    process.stdin.on("data", chunk => data += chunk);
    process.stdin.on("end", () => {
      try {
        const json = JSON.parse(data);
        const value = json[field];
        if (Array.isArray(value)) process.stdout.write(value.join(", "));
        else if (value !== undefined && value !== null) process.stdout.write(String(value));
      } catch {
        process.exit(2);
      }
    });
  ' "$field"
}

write_cookie_meta() {
  local tmp="$COOKIE_META_FILE.tmp.$$"
  "$NODE_BIN" -e '
    let data = "";
    process.stdin.on("data", chunk => data += chunk);
    process.stdin.on("end", () => {
      try {
        const json = JSON.parse(data);
        delete json.cookie;
        process.stdout.write(JSON.stringify(json, null, 2) + "\n");
      } catch {
        process.exit(2);
      }
    });
  ' > "$tmp" && mv "$tmp" "$COOKIE_META_FILE"
  local rc=$?
  [[ "$rc" == "0" ]] || rm -f "$tmp"
  return "$rc"
}

openconnect_args() {
  local -a args
  args=(
    "$OPENCONNECT_BIN"
    --protocol=nc
    --cookie-on-stdin
    --background
    --pid-file "$PID_FILE"
    --script "$VPNC_SCRIPT"
  )
  [[ "$OPENCONNECT_NO_DTLS" == "1" ]] && args+=(--no-dtls)
  if [[ -n "$OPENCONNECT_EXTRA_ARGS" ]]; then
    args+=(${=OPENCONNECT_EXTRA_ARGS})
  fi
  args+=("$SERVER")
  print -r -- "${(@q)args}"
}

signal_tracked_openconnect() {
  local signal="$1"
  local pid
  pid="$(pid_from_file 2>/dev/null)" || return 0
  if ! pid_running "$pid"; then
    rm -f "$PID_FILE"
    return 0
  fi
  kill "-$signal" "$pid" >/dev/null 2>&1 || true
  sleep 1
  [[ "$signal" == "HUP" || "$signal" == "TERM" ]] && rm -f "$PID_FILE"
}

start_openconnect_with_cookie() {
  local json="$1"
  local physical_default="${2:-}"
  local cookie
  if ! print -r -- "$json" | write_cookie_meta; then
    log "Cookie helper returned invalid JSON."
    return 1
  fi
  cookie="$(print -r -- "$json" | json_field cookie || true)"
  [[ -n "$cookie" ]] || {
    log "No VPN cookie available."
    return 1
  }

  [[ -x "$OPENCONNECT_BIN" ]] || {
    log "OpenConnect missing: $OPENCONNECT_BIN"
    return 1
  }
  [[ -x "$VPNC_SCRIPT" ]] || {
    log "vpnc-script missing: $VPNC_SCRIPT"
    return 1
  }

  local -a args
  args=(${(Q)${(z)$(openconnect_args)}})
  log "Starting OpenConnect."
  if ! print -rn -- "$cookie" | "${args[@]}" >> "$OPENCONNECT_LOG_FILE" 2>&1; then
    log "OpenConnect start command failed."
    return 1
  fi
  if [[ ! -f "$PID_FILE" ]]; then
    log "OpenConnect did not write pid file."
    return 1
  fi
  if [[ "$PRESERVE_DEFAULT_ROUTE" == "1" ]]; then
    restore_default_route "$physical_default" "after OpenConnect start" >/dev/null 2>&1 || true
    sleep "$DEFAULT_ROUTE_RESTORE_DELAY_SECONDS"
    restore_default_route "$physical_default" "after OpenConnect route script" >/dev/null 2>&1 || true
  fi
  ensure_vpn_split_routes "after OpenConnect route script"
  return 0
}

command_connect() {
  require_root
  if [[ "$COMMAND" == "connect" ]]; then
    reset_browser_session_attempts "manual connect"
  fi
  local pid
  if pid="$(pid_from_file 2>/dev/null)" && pid_running "$pid"; then
    if vpn_session_ok; then
      route_guard_tick
      reset_browser_session_attempts "connectivity OK"
      log "OpenConnect already running as pid $pid."
      return 0
    fi
    if browser_session_blocked; then
      log "VPN reconnect is blocked by the browser session attempt limit; run '$PROGRAM_NAME connect' after manual recovery."
      return "$BROWSER_SESSION_BLOCK_RC"
    fi
    log "OpenConnect is running as pid $pid, but the health check failed ($(health_check_description)); logging out before reconnecting."
    signal_tracked_openconnect TERM
    sleep 2
  fi

  if browser_session_blocked; then
    log "VPN reconnect is blocked by the browser session attempt limit; run '$PROGRAM_NAME connect' after manual recovery."
    return "$BROWSER_SESSION_BLOCK_RC"
  fi

  repair_stale_vpn_server_route
  route_guard_tick

  if vpn_session_ok; then
    reset_browser_session_attempts "connectivity OK"
    log "Connectivity is already OK ($(health_check_description)); not starting a duplicate tunnel."
    return 0
  fi

  local physical_default
  physical_default="$(primary_physical_default_route_info || saved_physical_default_route_info || true)"
  remember_physical_default_route "$physical_default" >/dev/null 2>&1 || true

  local json rc
  if json="$(run_cookie_helper)"; then
    :
  else
    rc=$?
    log "Cookie helper failed."
    block_browser_session_attempts_if_exhausted "cookie helper failed" || return "$?"
    return "$rc"
  fi

  if start_openconnect_with_cookie "$json" "$physical_default"; then
    return 0
  fi
  block_browser_session_attempts_if_exhausted "OpenConnect failed after browser session attempt" || return "$?"
  log "Not forcing a second browser login in the same connect cycle."
  return 1
}

command_disconnect() {
  require_root
  signal_tracked_openconnect HUP
  log "Disconnected tracked OpenConnect with SIGHUP."
}

command_logout() {
  require_root
  signal_tracked_openconnect TERM
  log "Terminated tracked OpenConnect with SIGTERM."
}

command_pause() {
  require_root
  set_auto_reconnect_paused "manual pause"
}

command_resume() {
  require_root
  clear_auto_reconnect_paused "manual resume"
}

command_disable() {
  require_root
  set_auto_reconnect_paused "manual disable"
  signal_tracked_openconnect TERM
  log "Disabled automatic reconnect and logged out tracked OpenConnect."
}

command_enable() {
  require_root
  local old_command rc
  clear_auto_reconnect_paused "manual enable"
  old_command="$COMMAND"
  COMMAND=connect
  command_connect
  rc=$?
  COMMAND="$old_command"
  return "$rc"
}

command_status() {
  local target health_status target_route_status ip any cookie_summary
  local health_detail
  health_detail="$(health_check_description)"
  if vpn_session_ok; then
    health_status="OK ($health_detail)"
  else
    health_status="FAIL ($health_detail)"
  fi
  target="$(health_check_route_target || true)"
  target_route_status="not checked"
  if [[ -n "$target" ]]; then
    target_route_status="$(route_get "$target" | /usr/bin/awk '
      /gateway:/ { gateway=$2 }
      /interface:/ { iface=$2 }
      END {
        if (gateway || iface) print (gateway ? gateway : "direct") " on " (iface ? iface : "unknown")
      }
    ' || true)"
    [[ -n "$target_route_status" ]] || target_route_status="not found"
  fi
  ip="$(vpn_internal_ip || true)"
  [[ -n "$ip" ]] || ip="not found"
  any="$(any_openconnect 2>/dev/null || true)"
  local current_default_info current_default_status="not found"
  current_default_info="$(default_route_info || true)"
  if [[ -n "$current_default_info" ]]; then
    local -a current_default_parts
    current_default_parts=("${(@ps:|:)current_default_info}")
    current_default_status="${current_default_parts[1]:-unknown} on ${current_default_parts[2]:-unknown}"
    if is_tunnel_iface "${current_default_parts[2]:-}"; then
      current_default_status="$current_default_status (WARNING: VPN owns default route)"
    elif [[ "$PRESERVE_DEFAULT_ROUTE" == "1" ]]; then
      current_default_status="$current_default_status (guard active)"
    fi
  fi

  local server_info default_info server_route_status=""
  server_info="$(vpn_server_route_info || true)"
  if [[ -n "$server_info" ]]; then
    local -a server_parts default_parts
    server_parts=("${(@ps:|:)server_info}")
    default_info="$(default_route_info "${server_parts[3]:-}" || true)"
    default_parts=("${(@ps:|:)default_info}")
    if [[ -n "${default_parts[1]:-}" && "${server_parts[3]:-}" == "${default_parts[2]:-}" &&
          -n "${server_parts[2]:-}" && "${server_parts[2]:-}" != "${default_parts[1]:-}" ]]; then
      server_route_status=" stale; default gateway ${default_parts[1]}"
    fi
  fi

  print "Label:        $LABEL"
  print "Config:       $CONFIG_FILE"
  print "Tracked:      $(tracked_pid_status)"
  print "VPN IP:       $ip"
  print "Health:      $health_status"
  print "Health route: $target_route_status"
  print "Default route: $current_default_status"
  print "Auto:         $(auto_reconnect_status)"
  print "Browser tries: $(browser_session_budget_status)"
  [[ -n "$server_info" ]] && print "VPN gateway:  ${server_parts[1]:-unknown} via ${server_parts[2]:-unknown} on ${server_parts[3]:-unknown}${server_route_status}"
  print "OpenConnect processes:"
  if [[ -n "$any" ]]; then
    print -r -- "$any" | sed 's/^/  /'
  else
    print "  none"
  fi
  if [[ -f "$COOKIE_META_FILE" ]]; then
    cookie_summary="$("$NODE_BIN" -e '
      const fs = require("fs");
      const json = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
      const dsid = (json.cookieExpiries || []).find((cookie) => cookie.name === "DSID");
      console.log(`${json.ok ? "present" : "missing"}; checked=${json.checkedAt || "unknown"}; DSID expiry ${dsid ? dsid.expiresAt : "unknown"}`);
    ' "$COOKIE_META_FILE" 2>/dev/null || true)"
    print "Cookie:       ${cookie_summary:-metadata unreadable}"
  else
    print "Cookie:       no metadata"
  fi
}

command_doctor() {
  print "Root:         $(id -u)"
  print "Label:        $LABEL"
  print "User:         $USER_NAME ($USER_UID) home=$USER_HOME"
  print "GUI session:  $(user_gui_available && print available || print missing)"
  print "Email:        ${UC_DAVIS_EMAIL:-not configured}"
  print "Node:         ${NODE_BIN:-not found} $([[ -n "$NODE_BIN" && -x "$NODE_BIN" ]] && print OK || print missing)"
  print "Helper:       ${COOKIE_HELPER:-not configured} $([[ -n "$COOKIE_HELPER" && -f "$COOKIE_HELPER" ]] && print OK || print missing)"
  print "OpenConnect:  $OPENCONNECT_BIN $([[ -x "$OPENCONNECT_BIN" ]] && print OK || print missing)"
  print "vpnc-script:  $VPNC_SCRIPT $([[ -x "$VPNC_SCRIPT" ]] && print OK || print missing)"
  print "Health check: $(resolved_health_check_mode) ($(health_check_description))"
  print "Auto:         $(auto_reconnect_status)"
  print "Browser tries: $(browser_session_budget_status)"
  local keychain_ok=1
  if [[ "$(id -u)" == "$USER_UID" ]]; then
    HOME="$USER_HOME" /usr/bin/security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$UC_DAVIS_EMAIL" >/dev/null 2>&1 && keychain_ok=0
  else
    /usr/bin/sudo -u "$USER_NAME" HOME="$USER_HOME" /usr/bin/security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$UC_DAVIS_EMAIL" >/dev/null 2>&1 && keychain_ok=0
  fi
  if [[ "$keychain_ok" == "0" ]]; then
    print "Keychain:     OK ($KEYCHAIN_SERVICE / $UC_DAVIS_EMAIL)"
  else
    print "Keychain:     missing or not accessible ($KEYCHAIN_SERVICE / $UC_DAVIS_EMAIL)"
  fi
}

monitor_once() {
  local health_detail
  route_guard_tick
  health_detail="$(health_check_description)"
  if vpn_session_ok; then
    log "Connectivity OK: $health_detail"
    reset_browser_session_attempts "connectivity OK"
    return 0
  fi

  log "Connectivity failed: $health_detail"
  [[ "$AUTO_RECONNECT" == "1" ]] || return 1
  if auto_reconnect_paused; then
    log "Auto reconnect is paused; skipping reconnect."
    return 0
  fi
  if browser_session_blocked; then
    log "Auto reconnect is paused by the browser session attempt limit; run '$PROGRAM_NAME connect' after manual recovery."
    return "$BROWSER_SESSION_BLOCK_RC"
  fi

  if [[ -f "$PID_FILE" ]]; then
    local pid
    if pid="$(pid_from_file 2>/dev/null)" && pid_running "$pid"; then
      log "Tracked OpenConnect is running but the health check failed; sending SIGTERM before reconnect."
      signal_tracked_openconnect TERM
    fi
  fi
  command_connect
}

command_once() {
  require_root
  monitor_once
}

command_run() {
  require_root
  acquire_run_lock
  setup_control_dir
  initialize_network_signature
  log "Starting daemon loop. interval=${CHECK_INTERVAL_SECONDS}s threshold=$FAILURE_THRESHOLD auto=$AUTO_RECONNECT connect_on_start=$CONNECT_ON_START"
  local failures=0
  local last_attempt=0
  local rc=0
  local blocked_logged=0

  process_control_requests

  if [[ "$CONNECT_ON_START" == "1" && ! -f "$AUTO_RECONNECT_PAUSE_FILE" ]]; then
    route_guard_tick
    if ! vpn_session_ok; then
      log "Startup connectivity check failed; trying connect."
      if command_connect; then
        last_attempt="$(date +%s)"
      else
        rc=$?
        if (( rc == RETRY_WITHOUT_COOLDOWN_RC )); then
          log "Startup connect skipped full reconnect cooldown because GUI login is not ready."
        elif (( rc == BROWSER_SESSION_BLOCK_RC )); then
          log "Startup connect is paused by the browser session attempt limit."
        else
          last_attempt="$(date +%s)"
        fi
      fi
    fi
  fi

  while true; do
    local now network_change_summary network_changed health_detail
    process_control_requests
    detect_network_change >/dev/null 2>&1 || true
    network_change_summary="$(consume_network_change_pending || true)"
    network_changed=0
    if [[ -n "$network_change_summary" ]]; then
      network_changed=1
      failures=0
      log "Network change detected; repairing routes before VPN check ($network_change_summary)."
      if (( NETWORK_CHANGE_SETTLE_SECONDS > 0 )); then
        sleep "$NETWORK_CHANGE_SETTLE_SECONDS"
      fi
      repair_stale_vpn_server_route
    fi
    route_guard_tick
    if vpn_session_ok; then
      failures=0
      blocked_logged=0
      reset_browser_session_attempts "connectivity OK"
    else
      if auto_reconnect_paused; then
        sleep_with_control "$CHECK_INTERVAL_SECONDS"
        continue
      fi
      if browser_session_blocked; then
        if (( blocked_logged == 0 )); then
          log "Auto reconnect is paused by the browser session attempt limit; run '$PROGRAM_NAME connect' after manual recovery."
          blocked_logged=1
        fi
        sleep_with_control "$CHECK_INTERVAL_SECONDS"
        continue
      fi
      blocked_logged=0
      failures=$((failures + 1))
      if (( network_changed == 1 )); then
        failures="$FAILURE_THRESHOLD"
      fi
      health_detail="$(health_check_description)"
      log "Monitor failure $failures/$FAILURE_THRESHOLD for $health_detail"
      now="$(date +%s)"
      if [[ "$AUTO_RECONNECT" == "1" ]] &&
         (( failures >= FAILURE_THRESHOLD )) &&
         (( NETWORK_CHANGE_BYPASS_COOLDOWN == 1 && network_changed == 1 || now - last_attempt >= RECONNECT_COOLDOWN_SECONDS )); then
        if (( network_changed == 1 )); then
          log "Checking VPN immediately after network change."
        fi
        if monitor_once; then
          last_attempt="$now"
          failures=0
        else
          rc=$?
          if (( rc == RETRY_WITHOUT_COOLDOWN_RC )); then
            log "Reconnect prerequisites are not ready; retrying on the next monitor cycle."
          elif (( rc == BROWSER_SESSION_BLOCK_RC )); then
            log "Auto reconnect is now paused by the browser session attempt limit."
          else
            last_attempt="$now"
            failures=0
          fi
        fi
      fi
    fi
    sleep_with_control "$CHECK_INTERVAL_SECONDS"
  done
}

if [[ "${UC_DAVIS_VPN_DAEMON_SOURCE_ONLY:-0}" == "1" ]]; then
  return 0 2>/dev/null || exit 0
fi

case "$COMMAND" in
  run) command_run ;;
  once) command_once ;;
  status) command_status ;;
  connect) command_connect ;;
  disconnect) command_disconnect ;;
  logout) command_logout ;;
  pause) command_pause ;;
  resume) command_resume ;;
  disable) command_disable ;;
  enable) command_enable ;;
  doctor) command_doctor ;;
  help) usage ;;
esac
