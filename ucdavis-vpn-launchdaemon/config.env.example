# zsh-style config for the root LaunchDaemon.

LABEL=local.ucdavis-openconnect-daemon

# The browser login helper must run in this user's GUI session.
USER_NAME=__USER_NAME__
USER_UID=__USER_UID__
USER_HOME=__USER_HOME__

SERVER=vpn.engineering.ucdavis.edu
UC_DAVIS_EMAIL=your_email@ucdavis.edu
KEYCHAIN_SERVICE=ucdavis-openconnect-vpn

# Monitor target. If PING_TARGET is empty, SSH_HOST_ALIAS is resolved from
# the user's ~/.ssh/config with `ssh -G`.
SSH_HOST_ALIAS=
PING_TARGET=
PING_COUNT=2
PING_TIMEOUT_MS=1500
SSH_CONFIG_TIMEOUT_SECONDS=5

# Daemon behavior.
CHECK_INTERVAL_SECONDS=60
FAILURE_THRESHOLD=2
RECONNECT_COOLDOWN_SECONDS=180
VERIFY_AFTER_CONNECT_SECONDS=25
GUI_SESSION_WAIT_SECONDS=0
GUI_SESSION_POLL_SECONDS=1
MAX_BROWSER_SESSION_ATTEMPTS=2
CONTROL_POLL_SECONDS=1
PRESERVE_DEFAULT_ROUTE=1
DEFAULT_ROUTE_RESTORE_DELAY_SECONDS=2
VPN_SPLIT_ROUTES="169.237.0.0/16 128.120.0.0/16"
VPN_ROUTE_PING_TARGET=1
AUTO_RECONNECT=1
CONNECT_ON_START=1

# Browser/SAML cookie helper from the user-level OpenConnect tool.
NODE_BIN=
COOKIE_HELPER="__PROJECT_ROOT__/ucdavis-openconnect-vpn/bin/ucdavis-vpn-cookie.mjs"

# OpenConnect runs as root from the daemon, so no sudo is needed here.
OPENCONNECT_BIN=/opt/homebrew/bin/openconnect
VPNC_SCRIPT=/opt/homebrew/etc/vpnc/vpnc-script
OPENCONNECT_NO_DTLS=1
OPENCONNECT_EXTRA_ARGS=

# Persistent browser login profile. The visible window is closed after cookie
# capture, but the profile remains for future reuse.
CHROME_PROFILE_DIR=__USER_HOME__/.local/state/ucdavis-vpn-chrome-profile
CHROME_CDP_PORT=9223
CHROME_APP="Google Chrome"
CLOSE_WINDOW_AFTER_COOKIE=1
CLOSE_EXISTING_VPN_SESSIONS=1

STATE_DIR=/var/run/ucdavis-openconnect-daemon
DB_DIR=/var/db/ucdavis-openconnect-daemon
LOG_DIR=/var/log/ucdavis-openconnect-daemon
