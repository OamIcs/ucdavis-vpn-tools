# zsh-style config for bin/ucdavis-openconnect-vpn.

SERVER=vpn.engineering.ucdavis.edu
UC_DAVIS_EMAIL=your_email@ucdavis.edu
KEYCHAIN_SERVICE=ucdavis-openconnect-vpn

# Reachability check. If PING_TARGET is empty, SSH_HOST_ALIAS is resolved
# with `ssh -G`, so aliases from ~/.ssh/config work.
SSH_HOST_ALIAS=
PING_TARGET=
PING_COUNT=2
PING_TIMEOUT_MS=1500
VERIFY_AFTER_CONNECT_SECONDS=25

# Persistent Chrome profile used only for VPN SAML login cookies.
CHROME_PROFILE_DIR="$HOME/.local/state/ucdavis-vpn-chrome-profile"
CHROME_CDP_PORT=9223
CHROME_APP="Google Chrome"
CLOSE_WINDOW_AFTER_COOKIE=1
CLOSE_EXISTING_VPN_SESSIONS=1

# OpenConnect runtime.
OPENCONNECT_BIN=/opt/homebrew/bin/openconnect
VPNC_SCRIPT=/opt/homebrew/etc/vpnc/vpnc-script
USE_SUDO=1
OPENCONNECT_NO_DTLS=1
OPENCONNECT_EXTRA_ARGS=

STATE_DIR="$HOME/.local/state/ucdavis-openconnect-vpn"
LOG_DIR="$HOME/Library/Logs/ucdavis-openconnect-vpn"
